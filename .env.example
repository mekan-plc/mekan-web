# -----------------------------------------------------------------------------
# Mekan Web - Frontend Environment Variables
#
# HOW TO USE
# 1. Copy this file to .env
# 2. Replace all example values with the correct local or production URLs
# 3. Never commit .env; it is intentionally gitignored
# -----------------------------------------------------------------------------

# Public website URL used for canonical URLs, sitemap generation, OpenGraph, and metadata.
PUBLIC_SITE_URL=https://mekanplc.com

# Public WordPress/CMS root URL used by browser-side fetches and health checks.
PUBLIC_CMS_BASE_URL=https://your-cms-domain.com

# Server-side WordPress REST API base used by Astro during builds/SSR.
WP_API_BASE=https://your-cms-domain.com/wp-json/wp/v2

# Server-side WordPress root URL used by API routes such as /api/contact.
WP_ROOT_BASE=https://your-cms-domain.com

# Server-side cache TTL for WordPress REST responses, in seconds.
# Use 0 during local content testing if you need every refresh to fetch fresh CMS data.
WP_CACHE_TTL_SECONDS=60