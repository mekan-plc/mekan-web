---
import Layout from '../layouts/Layout.astro';

const values = [
	{
		title: 'Excellence',
		description: 'We pursue the highest standards in everything we do, from technical recommendations to client relationships.'
	},
	{
		title: 'Integrity',
		description: 'Honest, transparent advice that prioritizes client success over short-term gains.'
	},
	{
		title: 'Innovation',
		description: 'Continuously evolving our approaches to meet emerging challenges in global agribusiness.'
	},
	{
		title: 'Impact',
		description: 'Measurable results that create lasting positive change for clients and communities.'
	},
	{
		title: 'Partnership',
		description: 'Working alongside clients as true partners, not just service providers.'
	},
	{
		title: 'Sustainability',
		description: 'Championing practices that protect our environment while ensuring economic viability.'
	}
];

const stats = [
	{ number: '15+', label: 'Years of Experience' },
	{ number: '500+', label: 'Clients Served' },
	{ number: '50+', label: 'Annual Certifications' },
	{ number: '15+', label: 'Districts Reached' }
];

const team = [
	{
		name: 'Abebe Kebede',
		role: 'Managing Director',
		bio: '20+ years in agricultural quality management and international certifications.',
		image: '/team/abebe.jpg'
	},
	{
		name: 'Meseret Tadesse',
		role: 'Lead Consultant',
		bio: 'Expert in GlobalG.A.P. and EU export compliance for horticultural products.',
		image: '/team/meseret.jpg'
	},
	{
		name: 'Dawit Hailu',
		role: 'Senior Advisor',
		bio: 'Specializes in climate resilience and sustainable agriculture systems.',
		image: '/team/dawit.jpg'
	}
];
---


<Layout title="About | Mekan" overlayNav>
	<section class="relative text-white overflow-hidden">
		{/* Background image - logo */}
		<div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/logo.png');"></div>
		{/* Navy overlay with transparency */}
		<div class="absolute inset-0 bg-[#0F2C59]/90"></div>
		{/* Content */}
		<div class="relative container pt-32 pb-28">
			{/* Breadcrumb - top left */}
			<nav class="flex items-center gap-2 text-sm text-white/70 mb-6">
				<a href="/" class="hover:text-white transition-colors flex items-center gap-1">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
					</svg>
					Home
				</a>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
				<span class="text-white font-medium">About</span>
			</nav>
			<h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-center">About Mekan</h1>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="grid gap-12 lg:grid-cols-2 items-center">
				<div>
					<h2 class="text-2xl font-semibold tracking-tight">Our Story</h2>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Founded in 2009, Mekan Quality Management & Training PLC emerged from a vision to transform Ethiopian agribusiness through international quality standards. What started as a small consultancy has grown into a trusted partner for hundreds of farmers, cooperatives, and agro-processors across East Africa.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Our team combines deep technical expertise in food safety systems, certification standards, and sustainable agriculture with intimate knowledge of local contexts and challenges. This unique blend enables us to deliver solutions that are both internationally credible and locally implementable.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Today, we stand at the forefront of Ethiopia's agricultural transformation, helping businesses access premium markets, improve productivity, and build resilience against climate and economic challenges.
					</p>
				</div>
				<div class="card p-8">
					<h3 class="text-lg font-semibold mb-6">By the Numbers</h3>
					<div class="grid grid-cols-2 gap-6">
						{stats.map((stat) => (
							<div>
								<div class="text-4xl font-bold text-[hsl(var(--brand))]">{stat.number}</div>
								<p class="mt-1 text-sm text-[hsl(var(--muted-foreground))]">{stat.label}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* MISSION & VISION - Dark cards with gold accent */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="grid gap-6 md:grid-cols-2">
				{/* Mission Card */}
				<div class="relative rounded-2xl bg-slate-100 dark:bg-[#1F2937] p-8 md:p-10 overflow-hidden">
					<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
					<div class="relative">
						<div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-[#0F2C59] dark:text-[#7EA2CE]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<h3 class="text-2xl font-semibold text-[#0F2C59] dark:text-[#7EA2CE] mb-4">Our Mission</h3>
						<p class="text-slate-700 dark:text-white/80 leading-relaxed">
							To elevate Ethiopian agribusiness through rigorous quality management, sustainable practices, and market-access expertise—empowering farmers and agro-processors to compete confidently in premium global markets.
						</p>
					</div>
				</div>

				{/* Vision Card */}
				<div class="relative rounded-2xl bg-slate-100 dark:bg-[#1F2937] p-8 md:p-10 overflow-hidden">
					<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
					<div class="relative">
						<div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center mb-6">
							<svg class="w-6 h-6 text-[#0F2C59] dark:text-[#7EA2CE]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
							</svg>
						</div>
						<h3 class="text-2xl font-semibold text-[#0F2C59] dark:text-[#7EA2CE] mb-4">Our Vision</h3>
						<p class="text-slate-700 dark:text-white/80 leading-relaxed">
							A thriving Ethiopia where world-class agricultural standards are the norm, not the exception. Where every farmer and agro-processor has the knowledge, certification, and partnerships to succeed in global markets—sustainably and profitably.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-12">
				<h2 class="text-3xl font-semibold tracking-tight">Our Values</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))]">
					The principles that guide every decision we make and every relationship we build.
				</p>
			</div>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{values.map((value) => (
					<div class="relative rounded-2xl bg-slate-100 dark:bg-[#1F2937] p-6 overflow-hidden">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE] mb-2">{value.title}</h3>
							<p class="text-sm leading-relaxed text-slate-700 dark:text-white/80">
								{value.description}
							</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-12">
				<h2 class="text-3xl font-semibold tracking-tight">Leadership Team</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))]">
					Experienced professionals dedicated to transforming Ethiopian agribusiness.
				</p>
			</div>
			<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				{team.map((member) => (
					<div class="relative rounded-2xl bg-slate-100 dark:bg-[#1F2937] overflow-hidden group">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							{/* Rectangular image container - larger */}
							<div class="aspect-[4/3] w-full bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/10 overflow-hidden">
								{member.image ? (
									<img
										src={member.image}
										alt={member.name}
										class="w-full h-full object-cover object-center"
									/>
								) : (
									<div class="w-full h-full flex items-center justify-center">
										<svg class="w-16 h-16 text-[#0F2C59]/40 dark:text-[#7EA2CE]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
										</svg>
									</div>
								)}
							</div>
							{/* Content area */}
							<div class="p-6">
								<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE]">{member.name}</h3>
								<p class="text-sm text-slate-600 dark:text-white/60 font-medium mt-1">{member.role}</p>
								<p class="mt-3 text-sm leading-relaxed text-slate-700 dark:text-white/70">{member.bio}</p>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

</Layout>
