---
import Layout from '../layouts/Layout.astro';

const values = [
	{
		title: 'Excellence',
		description: 'We pursue the highest standards in everything we do, from technical recommendations to client relationships.'
	},
	{
		title: 'Integrity',
		description: 'Honest, transparent advice that prioritizes client success over short-term gains.'
	},
	{
		title: 'Innovation',
		description: 'Continuously evolving our approaches to meet emerging challenges in global agribusiness.'
	},
	{
		title: 'Impact',
		description: 'Measurable results that create lasting positive change for clients and communities.'
	},
	{
		title: 'Partnership',
		description: 'Working alongside clients as true partners, not just service providers.'
	},
	{
		title: 'Sustainability',
		description: 'Championing practices that protect our environment while ensuring economic viability.'
	}
];

const stats = [
	{ number: '15+', label: 'Years of Experience' },
	{ number: '500+', label: 'Clients Served' },
	{ number: '50+', label: 'Annual Certifications' },
	{ number: '15+', label: 'Districts Reached' }
];

const team = [
	{
		name: 'Abebe Kebede',
		role: 'Managing Director',
		bio: '20+ years in agricultural quality management and international certifications.'
	},
	{
		name: 'Meseret Tadesse',
		role: 'Lead Consultant',
		bio: 'Expert in GlobalG.A.P. and EU export compliance for horticultural products.'
	},
	{
		name: 'Dawit Hailu',
		role: 'Senior Advisor',
		bio: 'Specializes in climate resilience and sustainable agriculture systems.'
	}
];
---

<Layout title="About | Mekan">
	<section class="bg-[hsl(var(--brand))] text-[hsl(var(--brand-foreground))]">
		<div class="container py-24">
			<h1 class="text-3xl md:text-4xl font-semibold tracking-tight">About Mekan</h1>
			<p class="mt-4 text-lg text-[hsl(var(--brand-foreground))]/80 max-w-3xl">
				Bridging the gap between Ethiopian agriculture and global markets through world-class quality management and strategic consulting.
			</p>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))]">
		<div class="container">
			<div class="grid gap-12 lg:grid-cols-2 items-center">
				<div>
					<h2 class="text-2xl font-semibold tracking-tight">Our Story</h2>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Founded in 2009, Mekan Quality Management & Training PLC emerged from a vision to transform Ethiopian agribusiness through international quality standards. What started as a small consultancy has grown into a trusted partner for hundreds of farmers, cooperatives, and agro-processors across East Africa.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Our team combines deep technical expertise in food safety systems, certification standards, and sustainable agriculture with intimate knowledge of local contexts and challenges. This unique blend enables us to deliver solutions that are both internationally credible and locally implementable.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Today, we stand at the forefront of Ethiopia's agricultural transformation, helping businesses access premium markets, improve productivity, and build resilience against climate and economic challenges.
					</p>
				</div>
				<div class="card p-8 bg-[hsl(var(--muted))]">
					<h3 class="text-lg font-semibold mb-6">By the Numbers</h3>
					<div class="grid grid-cols-2 gap-6">
						{stats.map((stat) => (
							<div>
								<div class="text-4xl font-bold text-[hsl(var(--brand))]">{stat.number}</div>
								<p class="mt-1 text-sm text-[hsl(var(--muted-foreground))]">{stat.label}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section bg-[hsl(var(--muted))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-12">
				<h2 class="text-3xl font-semibold tracking-tight">Our Values</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))]">
					The principles that guide every decision we make and every relationship we build.
				</p>
			</div>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{values.map((value) => (
					<div class="card bg-[hsl(var(--background))] p-6">
						<h3 class="text-lg font-semibold text-[hsl(var(--brand))]">{value.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-[hsl(var(--muted-foreground))]">
							{value.description}
						</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-12">
				<h2 class="text-3xl font-semibold tracking-tight">Leadership Team</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))]">
					Experienced professionals dedicated to transforming Ethiopian agribusiness.
				</p>
			</div>
			<div class="grid gap-6 md:grid-cols-3">
				{team.map((member) => (
					<div class="card p-6 text-center">
						<div class="w-20 h-20 rounded-full bg-[hsl(var(--muted))] mx-auto flex items-center justify-center text-2xl">
							👤
						</div>
						<h3 class="mt-4 text-lg font-semibold">{member.name}</h3>
						<p class="text-sm text-[hsl(var(--brand))] font-medium">{member.role}</p>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">{member.bio}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="bg-[hsl(var(--brand))] py-16 text-[hsl(var(--brand-foreground))]">
		<div class="container text-center">
			<h2 class="text-2xl font-semibold tracking-tight">Ready to work with us?</h2>
			<p class="mt-3 text-[hsl(var(--brand-foreground))]/80 max-w-xl mx-auto">
				Let's discuss how our expertise can help your agribusiness reach new heights.
			</p>
			<a href="/contact" class="btn btn-brand mt-6 inline-block">
				Get in touch
			</a>
		</div>
	</section>
</Layout>
