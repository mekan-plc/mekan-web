---
import Layout from '../layouts/Layout.astro';

const title = "Terms of Service";
const description = "Terms and conditions governing the use of Mekan PLC's website and services.";

const sections = [
  { id: 'acceptance', num: '1', title: 'Acceptance of Terms', icon: 'check' },
  { id: 'services', num: '2', title: 'Services Description', icon: 'briefcase' },
  { id: 'website-use', num: '3', title: 'Website Use', icon: 'globe' },
  { id: 'intellectual', num: '4', title: 'Intellectual Property', icon: 'shield' },
  { id: 'consulting', num: '5', title: 'Consulting Services', icon: 'users' },
  { id: 'disclaimer', num: '6', title: 'Disclaimer', icon: 'alert' },
  { id: 'liability', num: '7', title: 'Limitation of Liability', icon: 'scale' },
  { id: 'governing', num: '8', title: 'Governing Law', icon: 'book' },
  { id: 'contact', num: '9', title: 'Contact Us', icon: 'mail' },
];

const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={title} description={description} overlayNav={true}>
  <!-- Hero Section -->
  <section class="relative bg-[#0F2C59] dark:bg-[#0F2C59] pt-40 pb-16 -mt-[72px]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm mb-8">
        <a href="/" class="flex items-center gap-1 px-3 py-1.5 rounded-full border border-white/20 text-white/80 hover:text-white hover:border-white/40 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Home
        </a>
        <span class="text-white/40">›</span>
        <span class="px-3 py-1.5 rounded-full border border-[#7EA2CE]/50 text-[#7EA2CE] bg-[#7EA2CE]/10">
          Terms of Service
        </span>
      </nav>

      <!-- Legal Label -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-[#7EA2CE]/50"></div>
        <span class="text-[#7EA2CE] text-sm tracking-widest uppercase font-medium">LEGAL</span>
        <div class="h-px w-12 bg-[#7EA2CE]/50"></div>
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-center text-[#7EA2CE] mb-4">
        Terms of Service
      </h1>

      <!-- Subtitle -->
      <p class="text-center text-white/80 text-lg mb-6">
        Please read these terms carefully before using our services.
      </p>

      <!-- Last Updated -->
      <div class="flex items-center justify-center gap-2 text-white/60 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>Last updated: {lastUpdated}</span>
      </div>
    </div>
  </section>

  <!-- Quick Navigation -->
  <section class="bg-[hsl(var(--background))] relative z-10 mt-6">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[hsl(var(--card))] rounded-xl shadow-lg p-6 sm:p-8 border border-[#0F2C59]/20 dark:border-[#7EA2CE]/20">
        <h2 class="text-[#0F2C59] dark:text-[#7EA2CE] text-lg font-semibold mb-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Quick Navigation
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {sections.map((section) => (
            <a 
              href={`#${section.id}`} 
              class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#0F2C59]/10 dark:hover:bg-[#7EA2CE]/10 transition-colors group"
            >
              <div class="w-8 h-8 rounded-lg bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] group-hover:bg-[#0F2C59] group-hover:text-white dark:group-hover:bg-[#7EA2CE] dark:group-hover:text-white dark:hover:text-[#0F2C59] transition-colors">
                <span class="text-sm font-bold">{section.num}</span>
              </div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] font-medium">{section.title}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="bg-[hsl(var(--background))] py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
      
      <!-- Section 1: Acceptance of Terms -->
      <div id="acceptance" class="bg-[hsl(var(--card))] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 1</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Acceptance of Terms</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            By accessing or using the Mekan Consultancy website, you agree to be bound by these Terms of Service. If you do not agree to all the terms and conditions, please do not use our website or services.
          </p>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed">
            These terms constitute a legally binding agreement between you and Mekan Consultancy PLC, an agribusiness consulting firm registered in Ethiopia.
          </p>
        </div>
      </div>

      <!-- Section 2: Services Description -->
      <div id="services" class="bg-[hsl(var(--card))] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 2</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Services Description</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            Mekan Consultancy provides professional consulting services in the agribusiness sector, including:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Agribusiness development and strategic growth consulting</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Investment advisory services for agricultural projects</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Market research and analysis</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Sustainability and climate resilience solutions</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Quality assurance and regulatory compliance guidance</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 3: Website Use -->
      <div id="website-use" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 3</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Website Use</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            You agree to use our website only for lawful purposes. Prohibited activities include:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Using the website in any way that could damage or impair our servers</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Attempting to gain unauthorized access to any systems</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Transmitting viruses, malware, or other harmful code</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Using the contact form to send spam or unsolicited communications</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 4: Intellectual Property -->
      <div id="intellectual" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 4</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Intellectual Property</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            All content on this website is the property of Mekan Consultancy and is protected by Ethiopian and international copyright laws.
          </p>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed">
            <strong>You may:</strong> View, download, and print content for personal, non-commercial use. Share links on social media. Quote brief excerpts with proper attribution.<br><br>
            <strong>You may not:</strong> Reproduce, distribute, or modify content without permission. Use content for commercial purposes. Remove copyright notices.
          </p>
        </div>
      </div>

      <!-- Section 5: Consulting Services -->
      <div id="consulting" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 5</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Consulting Services Agreement</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            Engagement of our professional services is governed by separate written agreements:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Confidentiality:</strong> We maintain strict confidentiality of all client information</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Professional Standards:</strong> Services performed per industry best practices</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Payment Terms:</strong> Fees established in writing prior to project commencement</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Intellectual Property:</strong> Work product becomes client property upon full payment</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 6: Disclaimer -->
      <div id="disclaimer" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 6</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Disclaimer of Warranties</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            This website and content are provided "as is". Mekan Consultancy makes no representations regarding:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>The accuracy or completeness of website content</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Uninterrupted or error-free operation of the website</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Results from using our consulting services</span>
            </li>
          </ul>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mt-4">
            All information is for informational purposes only and not professional advice.
          </p>
        </div>
      </div>

      <!-- Section 7: Limitation of Liability -->
      <div id="liability" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 7</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Limitation of Liability</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            To the fullest extent permitted by law, Mekan Consultancy shall not be liable for:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Direct, indirect, incidental, or consequential damages</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Loss of profits, revenue, data, or business opportunities</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Personal injury or property damage</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 8: Governing Law -->
      <div id="governing" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 8</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Governing Law and Dispute Resolution</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            These Terms are governed by the laws of the Federal Democratic Republic of Ethiopia. Disputes shall be resolved through:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
