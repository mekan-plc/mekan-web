---
import Layout from '../../layouts/Layout.astro';
import { listPosts } from '../../lib/wp';

const url = new URL(Astro.request.url);
const page = Number(url.searchParams.get('page') ?? '1') || 1;
const perPage = 9;

let posts: any[] = [];
let errorMessage: string | null = null;

try {
	({ posts } = await listPosts({ page, perPage }));
} catch (err) {
	errorMessage = err instanceof Error ? err.message : 'Failed to load posts.';
}

function formatDate(dateStr: string) {
	return new Date(dateStr).toLocaleDateString('en-US', { 
		year: 'numeric', 
		month: 'long', 
		day: 'numeric' 
	});
}

function stripHtml(html: string) {
	return html.replace(/<[^>]*>/g, '').substring(0, 150) + '...';
}
---

<Layout title="Insights | Mekan">
	<section class="bg-[hsl(var(--brand))] text-[hsl(var(--brand-foreground))]">
		<div class="container py-24">
			<h1 class="text-3xl md:text-4xl font-semibold tracking-tight">Insights & Resources</h1>
			<p class="mt-4 text-lg text-[hsl(var(--brand-foreground))]/80 max-w-2xl">
				Latest thinking on quality standards, market access, sustainable agriculture, and agribusiness growth strategies.
			</p>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))]">
		<div class="container">
			{errorMessage ? (
				<div class="card p-8 text-center">
					<p class="text-[hsl(var(--muted-foreground))]">Unable to load blog posts at this time.</p>
					<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">{errorMessage}</p>
				</div>
			) : posts.length === 0 ? (
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{/* Sample Blog Post 1 */}
					<a 
						href="/blog/global-gap-certification-guide-2024"
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
							<div class="text-5xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">🌱</div>
							<div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[hsl(var(--brand))]/90 text-[hsl(var(--brand-foreground))] text-xs font-medium">Certification</div>
						</div>
						<div class="relative p-6 flex flex-col flex-grow">
							<p class="text-xs text-[hsl(var(--muted-foreground))]">January 15, 2024</p>
							<h2 class="mt-2 text-lg font-semibold leading-snug text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
								The Complete Guide to GlobalG.A.P. Certification for Ethiopian Exporters
							</h2>
							<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow line-clamp-3">
								Navigate the complex world of GlobalG.A.P. certification with our comprehensive guide. Learn step-by-step how Ethiopian agricultural exporters can achieve and maintain this crucial certification.
							</p>
							<div class="mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
								<span class="transition-transform duration-300 group-hover:translate-x-1">Read article</span>
								<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</div>
						</div>
					</a>

					{/* Sample Blog Post 2 */}
					<a 
						href="/blog/sustainable-farming-practices-2024"
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
							<div class="text-5xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">🌍</div>
							<div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[hsl(var(--brand))]/90 text-[hsl(var(--brand-foreground))] text-xs font-medium">Sustainability</div>
						</div>
						<div class="relative p-6 flex flex-col flex-grow">
							<p class="text-xs text-[hsl(var(--muted-foreground))]">January 10, 2024</p>
							<h2 class="mt-2 text-lg font-semibold leading-snug text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
								5 Sustainable Farming Practices Transforming Ethiopian Agriculture
							</h2>
							<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow line-clamp-3">
								Discover innovative sustainable farming practices reshaping agriculture across Ethiopia. From water conservation to integrated pest management.
							</p>
							<div class="mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
								<span class="transition-transform duration-300 group-hover:translate-x-1">Read article</span>
								<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</div>
						</div>
					</a>

					{/* Sample Blog Post 3 */}
					<a 
						href="/blog/eu-export-compliance-2024"
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
							<div class="text-5xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📊</div>
							<div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[hsl(var(--brand))]/90 text-[hsl(var(--brand-foreground))] text-xs font-medium">Compliance</div>
						</div>
						<div class="relative p-6 flex flex-col flex-grow">
							<p class="text-xs text-[hsl(var(--muted-foreground))]">January 5, 2024</p>
							<h2 class="mt-2 text-lg font-semibold leading-snug text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
								EU Export Compliance: New Regulations Ethiopian Agribusinesses Must Know
							</h2>
							<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow line-clamp-3">
								Stay ahead of changing EU regulations with our comprehensive overview of new compliance requirements for Ethiopian exporters.
							</p>
							<div class="mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
								<span class="transition-transform duration-300 group-hover:translate-x-1">Read article</span>
								<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</div>
						</div>
					</a>
				</div>
			) : (
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{posts.map((post: any, index: number) => (
						<a 
							href={`/blog/${post.slug}`}
							class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
						>
							<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
							<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
								<div class="text-5xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📝</div>
								<div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-[hsl(var(--brand))]/90 text-[hsl(var(--brand-foreground))] text-xs font-medium">Article</div>
							</div>
							<div class="relative p-6 flex flex-col flex-grow">
								<p class="text-xs text-[hsl(var(--muted-foreground))]">{formatDate(post.date)}</p>
								<h2 class="mt-2 text-lg font-semibold leading-snug text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]" set:html={post.title?.rendered ?? ''} />
								<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow line-clamp-3">
									{stripHtml(post.excerpt?.rendered ?? '')}
								</p>
								<div class="mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
									<span class="transition-transform duration-300 group-hover:translate-x-1">Read article</span>
									<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</div>
							</div>
						</a>
					))}
				</div>
			)}

			{posts.length > 0 && (
				<div class="mt-12 flex justify-center gap-2">
					{page > 1 && (
						<a 
							href={`?page=${page - 1}`}
							class="btn btn-secondary"
						>
							← Previous
						</a>
					)}
					{posts.length === perPage && (
						<a 
							href={`?page=${page + 1}`}
							class="btn btn-secondary"
						>
							Next →
						</a>
					)}
				</div>
			)}
		</div>
	</section>

	<section class="bg-[hsl(var(--brand))] py-16 text-[hsl(var(--brand-foreground))]">
		<div class="container text-center">
			<h2 class="text-2xl font-semibold tracking-tight">Want to contribute?</h2>
			<p class="mt-3 text-[hsl(var(--brand-foreground))]/80 max-w-xl mx-auto">
				We welcome guest articles from industry experts. Share your knowledge with our community of agribusiness professionals.
			</p>
			<a href="/contact" class="btn btn-brand mt-6 inline-block">
				Get in touch
			</a>
		</div>
	</section>
</Layout>
