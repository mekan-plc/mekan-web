---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog" description="Insights from Mekan PLC on quality management, compliance, certification readiness, and training for agribusiness in Ethiopia." overlayNav>
	<div class="min-h-screen bg-[hsl(var(--background))]">
		{/* Hero Section */}
		<section class="relative text-white overflow-hidden">
			<div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/logo.png');"></div>
			<div class="absolute inset-0 bg-[#0F2C59]/90"></div>
			<div class="relative container pt-32 pb-28">
				<h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Insights & Blog</h1>
				<p class="text-lg md:text-xl text-white/80 max-w-3xl">
					Latest thinking on quality standards, market access, sustainable agriculture, and agribusiness growth strategies.
				</p>
			</div>
		</section>

		{/* Blog Grid */}
		<section class="py-16 md:py-24">
			<div class="container">
				<div id="blogError" class="hidden mb-8 p-4 rounded-lg bg-red-50 text-red-600"></div>
				<div id="staticBanner" class="hidden mb-6 p-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm text-center">
					<span class="font-semibold">Hey you should really give it a taught</span>
				</div>
				<div id="blogGrid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3"></div>
			</div>
		</section>
	</div>

	<script>
		const CMS_BASE = (import.meta.env.PUBLIC_CMS_BASE_URL || 'http://localhost:8881').replace(/\/$/, '');
		const grid = document.getElementById('blogGrid');
		const errorEl = document.getElementById('blogError');
		const CACHE_TTL_MS = 5 * 60 * 1000;
		const CACHE_PREFIX = 'mekan_cache_v1:';

		function cacheGet(key) {
			try {
				const raw = sessionStorage.getItem(CACHE_PREFIX + key);
				if (!raw) return null;
				const parsed = JSON.parse(raw);
				if (!parsed || typeof parsed !== 'object') return null;
				if (typeof parsed.ts !== 'number') return null;
				if (Date.now() - parsed.ts > CACHE_TTL_MS) return null;
				return parsed.data ?? null;
			} catch {
				return null;
			}
		}

		function cacheSet(key, data) {
			try {
				sessionStorage.setItem(CACHE_PREFIX + key, JSON.stringify({ ts: Date.now(), data }));
			} catch {
				// ignore
			}
		}

		function escapeHtml(str) {
			return String(str)
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#039;');
		}

		function renderSkeleton() {
			if (!grid) return;
			grid.innerHTML = Array.from({ length: 6 }).map(() => (
				`<article class="group bg-[hsl(var(--card))] rounded-2xl overflow-hidden border border-[hsl(var(--border))]">
					<div class="h-48 bg-[hsl(var(--muted))] animate-pulse"></div>
					<div class="p-6 space-y-3">
						<div class="h-3 w-1/3 bg-[hsl(var(--muted))] rounded animate-pulse"></div>
						<div class="h-4 w-4/5 bg-[hsl(var(--muted))] rounded animate-pulse"></div>
						<div class="h-3 w-full bg-[hsl(var(--muted))] rounded animate-pulse"></div>
					</div>
				</article>`
			)).join('');
		}

		function blogCard(blog) {
			const img = blog.imageUrl
				? `<img src="${escapeHtml(blog.imageUrl)}" alt="${escapeHtml(blog.title)}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />`
				: `<div class="w-full h-full flex items-center justify-center"><span class="text-5xl">📝</span></div>`;

			return `<article class="group bg-[hsl(var(--card))] rounded-2xl overflow-hidden border border-[hsl(var(--border))] transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
				<a href="/blog/${escapeHtml(blog.slug)}" class="block blog-link" data-slug="${escapeHtml(blog.slug)}">
					<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] overflow-hidden">
						${img}
						<div class="absolute top-4 left-4">
							<span class="px-3 py-1 rounded-full bg-[hsl(var(--brand))] text-[hsl(var(--brand-foreground))] text-xs font-medium">${escapeHtml(blog.category || '')}</span>
						</div>
					</div>
					<div class="p-6">
						<p class="text-sm text-[hsl(var(--muted-foreground))] mb-2">${escapeHtml(blog.date || '')}</p>
						<h2 class="text-xl font-semibold text-[hsl(var(--foreground))] mb-3 line-clamp-2 group-hover:text-[hsl(var(--brand))] transition-colors">${escapeHtml(blog.title || '')}</h2>
						<p class="text-sm text-[hsl(var(--muted-foreground))] line-clamp-3">${escapeHtml(blog.excerpt || '')}</p>
						<div class="mt-4 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))]">
							<span>Read More</span>
							<svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
						</div>
					</div>
				</a>
			</article>`;
		}

		async function prefetchBlogSlug(slug) {
			const key = `blog:${slug}`;
			if (cacheGet(key)) return;
			try {
				const url = `${CMS_BASE}/wp-json/mekan/v1/blogs/${encodeURIComponent(slug)}`;
				const res = await fetch(url, { headers: { Accept: 'application/json' } });
				if (!res.ok) return;
				const blog = await res.json();
				cacheSet(key, blog);
			} catch {
				// ignore
			}
		}

		function setupPrefetching() {
			const links = Array.from(document.querySelectorAll('a.blog-link'));
			links.forEach((a) => {
				a.addEventListener('mouseenter', () => {
					const slug = a.dataset.slug;
					if (slug) prefetchBlogSlug(slug);
				});
				a.addEventListener('touchstart', () => {
					const slug = a.dataset.slug;
					if (slug) prefetchBlogSlug(slug);
				}, { passive: true });
			});

			if ('IntersectionObserver' in window) {
				const io = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (!entry.isIntersecting) return;
						const a = entry.target;
						const slug = a.dataset.slug;
						if (slug) prefetchBlogSlug(slug);
						io.unobserve(a);
					});
				}, { rootMargin: '250px' });
				links.forEach((a) => io.observe(a));
			}
		}

		const STATIC_BLOGS = [
			{
				slug: 'sample-1',
				title: 'Introduction to GLOBALG.A.P Certification for Ethiopian Exporters',
				excerpt: 'Learn how GLOBALG.A.P certification opens doors to European markets and enhances food safety standards for Ethiopian agricultural producers.',
				category: 'Certification',
				date: 'January 15, 2026',
				imageUrl: null
			},
			{
				slug: 'sample-2',
				title: 'Maximizing Coffee Quality: Post-Harvest Processing Best Practices',
				excerpt: 'Discover the critical steps in coffee processing that can increase your cupping scores by 2-3 points and attract premium buyers.',
				category: 'Coffee',
				date: 'January 10, 2026',
				imageUrl: null
			},
			{
				slug: 'sample-3',
				title: 'Export Documentation Guide: From Farm to Port',
				excerpt: 'A comprehensive checklist of all documents needed for agricultural exports from Ethiopia, including phytosanitary certificates and customs declarations.',
				category: 'Export',
				date: 'January 5, 2026',
				imageUrl: null
			}
		];

		async function loadBlogs() {
			renderSkeleton();
			const cached = cacheGet('blogs:index');
			if (cached && Array.isArray(cached)) {
				if (grid) grid.innerHTML = cached.length ? cached.map(blogCard).join('') : `<div class="text-center py-16"><p class="text-[hsl(var(--muted-foreground))]">No blog posts found. Check back soon!</p></div>`;
				setupPrefetching();
			}
			try {
				const url = `${CMS_BASE}/wp-json/mekan/v1/blogs?per_page=12`;
				const res = await fetch(url, { headers: { Accept: 'application/json' } });
				if (!res.ok) throw new Error('Failed to load blog posts.');
				const blogs = await res.json();
				if (!Array.isArray(blogs)) throw new Error('Invalid blogs response.');
				cacheSet('blogs:index', blogs);
				if (grid) grid.innerHTML = blogs.length ? blogs.map(blogCard).join('') : `<div class="text-center py-16"><p class="text-[hsl(var(--muted-foreground))]">No blog posts found. Check back soon!</p></div>`;
				setupPrefetching();
			} catch (e) {
				if (!cached) {
					// Show static fallback content
					const banner = document.getElementById('staticBanner');
					if (banner) banner.classList.remove('hidden');
					if (grid) grid.innerHTML = STATIC_BLOGS.map(blogCard).join('');
					if (errorEl) errorEl.classList.add('hidden');
				}
			}
		}

		loadBlogs();
	</script>
</Layout>
