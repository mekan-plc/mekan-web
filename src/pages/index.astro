---
import Layout from '../layouts/Layout.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';
import { listFeaturedProjects, listBlogs } from '../lib/wp';

const { blogs: featuredBlogs } = await listBlogs({ perPage: 3, featured: true }).catch(() => ({ blogs: [] }));

const { projects } = await listFeaturedProjects({ perPage: 3 }).catch(() => ({ projects: [] }));

const contactInfo = {
	email: 'biniam@mekanplc.com',
	phone: '+251 911 454 671'
};

const services = [
	{
		id: 'quality-assurance',
		title: 'Quality Assurance & Regulatory Compliance',
		summary: 'Securing your license to operate with GAP, GHP, GMP, HACCP, BRCGS, and FSMS 22000. EU market entry, Private Label Standards, and Corporate Stewardship (CSR, ESG & ESMS).',
		icon: 'Shield'
	},
	{
		id: 'agribusiness-development',
		title: 'Agribusiness Development & Strategic Growth',
		summary: 'Scaling strategies, bespoke SME agronomy business plans, performance monitoring, B2B & value chain development, and executive coaching for long-term growth.',
		icon: 'TrendingUp'
	},
	{
		id: 'agricultural-productivity',
		title: 'Agricultural Productivity & Sustainability',
		summary: 'Global G.A.P implementation, postharvest handling & safety, IPM strategies, soil & water management, and Integrated Farm Management (IFM) for regenerative practices.',
		icon: 'Leaf'
	},
	{
		id: 'food-systems',
		title: 'Food Systems & Climate Resilience',
		summary: 'Food systems assessment & diagnostics, policy & strategy development, climate resilience & risk management, and nutrition-sensitive agricultural programming.',
		icon: 'Globe'
	},
	{
		id: 'global-standards',
		title: 'Global Standards & Certifications',
		summary: 'Your technical partner for Global G.A.P, GRASP, BRCGS, IFS, HACCP, FSMS 22000, Organic, Tesco Nurture, LEAF, and SMETA certifications.',
		icon: 'Award'
	},
	{
		id: 'investment-advisory',
		title: 'Private Sector & Investment Advisory',
		summary: 'Supply chain & logistics optimization, MEL systems, investment readiness advisory, data modelling, and project design & implementation support.',
		icon: 'BarChart'
	}
];

function formatDate(dateStr: string) {
	return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function stripHtml(html: string) {
	return html.replace(/<[^>]*>/g, '').substring(0, 120) + '...';
}
---

<Layout title="Mekan PLC | Quality Management, Compliance & Training" description="Mekan PLC provides quality management consulting, compliance support, certification readiness, and training services for agribusiness and related sectors in Ethiopia." overlayNav>
	<!-- Hero: World-Class Design -->
	<section id="home" class="relative w-full min-h-screen overflow-hidden flex pb-28 sm:pb-0">
		{/* LEFT PANEL - Premium Navy with Depth */}
		<div
			class="relative w-full lg:w-[46%] xl:w-[46%] text-[hsl(var(--brand-foreground))] flex flex-col justify-center px-6 sm:px-10 lg:px-14 xl:px-20 pt-20 pb-28 lg:pt-20 lg:pb-32 lg:min-h-screen z-10"
			style="background: linear-gradient(to right, #0A1628 0%, #0F2C59 25%, rgba(15, 44, 89, 0.9) 40%, rgba(15, 44, 89, 0.7) 55%, rgba(15, 44, 89, 0.4) 70%, rgba(15, 44, 89, 0.15) 85%, rgba(15, 44, 89, 0.05) 95%, transparent 100%);"
		>
			{/* Subtle pattern overlay */}
			<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
			
			{/* Glowing accent */}
			<div class="absolute top-1/4 -left-20 w-40 h-40 bg-[#7EA2CE]/20 rounded-full blur-3xl"></div>
			<div class="absolute bottom-1/4 -right-10 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
			
			<div class="relative z-10 max-w-xl lg:max-w-2xl">
				{/* Main Headline */}
				<h1 class="text-4xl sm:text-5xl lg:text-[3rem] xl:text-[3.25rem] font-bold tracking-tight leading-[1.06]">
					<span class="block text-white mb-1">Empowering Sustainable</span>
					<span class="block text-white mb-1">Growth in Agribusiness</span>
					<span class="block text-[#7EA2CE]">& the Supply Chain</span>
				</h1>
				
				{/* Subtitle - More breathing room */}
				<p class="mt-4 text-sm lg:text-base text-white/70 max-w-lg leading-relaxed">
					Comprehensive Consulting, Compliance, and Strategic Solutions for a Resilient Future.
				</p>
				
				{/* CTA Buttons - Professional */}
				<div class="mt-6 flex flex-wrap gap-4">
					<a 
						href="#contact" 
						class="group inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-[#0F2C59] transition-all hover:shadow-lg hover:scale-[1.02]"
					>
						<span>Get Started</span>
						<svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
					<a 
						href="#services" 
						class="group inline-flex items-center gap-2 rounded-lg border border-white/30 px-6 py-3 text-sm font-medium text-white transition-all hover:bg-white/10"
					>
						<span>Our Services</span>
						<svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</a>
				</div>
			</div>
		</div>

		{/* RIGHT PANEL - Clean images with subtle overlay */}
		<div class="hidden lg:block lg:w-[54%] xl:w-[54%] relative">
			{[1, 2, 3, 4, 5].map((num, index) => (
				<div
					class="absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1500 ease-in-out hero-slide"
					style={`
						background-image: url('/hero/${num}.jpg');
						opacity: ${index === 0 ? '1' : '0'};
						animation: heroFade 30s infinite;
						animation-delay: ${index * 6}s;
					`}
				/>
			))}
			{/* Left edge darkening overlay - seamless with navy gradient */}
			<div class="absolute inset-0 bg-gradient-to-r from-[#0F2C59]/60 via-[#0F2C59]/20 to-transparent"></div>
		</div>

		{/* PARTNERS MARQUEE - Positioned over hero (no separate background) */}
		<div class="absolute bottom-0 left-0 right-0 z-30">
			<div class="text-white">
				<div class="px-4 sm:px-8 py-3">
					<div class="mb-2 text-center">
						<span class="text-[9px] uppercase tracking-[0.25em] text-white/60">Trusted By Industry Leaders</span>
					</div>
					<PartnersMarquee overlay />
				</div>
			</div>
		</div>

		<style>
			@media (max-width: 1023px) {
				#home {
					background: linear-gradient(to right, #0A1628 0%, #0F2C59 25%, rgba(15, 44, 89, 0.9) 40%, rgba(15, 44, 89, 0.7) 55%, rgba(15, 44, 89, 0.4) 70%, rgba(15, 44, 89, 0.15) 85%, rgba(15, 44, 89, 0.05) 95%, transparent 100%);
				}
			}

			@keyframes heroFade {
				0%, 16% { opacity: 1; }
				20%, 96% { opacity: 0; }
				100% { opacity: 1; }
			}
		</style>
	</section>

	<!-- About: Same background, with top border -->
	<section id="about" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="grid gap-12 md:grid-cols-12 md:items-center">
				<!-- Text content - now on LEFT -->
				<div class="md:col-span-7">
					<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">About Us</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight">Your Technical Partner for World-Class Agribusiness</h2>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Located in the heart of Addis Ababa, Mekan Quality Management and Training PLC is a premier consultancy dedicated to bridging the gap between Ethiopian agribusiness and the global marketplace. We specialize in transforming the supply chain through technical excellence, regulatory mastery, and strategic foresight.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						As a comprehensive technical partner, we empower enterprises to navigate complex international standards—from EU market entry and Global G.A.P. certification to ESG corporate stewardship. By blending agronomic precision with data-driven corporate strategy, we help businesses optimize their value chains and achieve sustainable growth.
					</p>
					<div class="mt-8">
						<a href="/about" class="btn btn-primary">Explore more about us →</a>
					</div>
				</div>
				<!-- Stats - now on RIGHT -->
				<div class="md:col-span-5">
					<div class="card p-8">
						<div class="text-4xl font-bold text-[hsl(var(--brand))]">8+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Years of excellence (established 2018 GC)</p>
						<div class="mt-6 text-4xl font-bold text-[hsl(var(--brand))]">50+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Clients served across agribusiness and supply chains</p>
						<div class="mt-6 text-4xl font-bold text-[hsl(var(--brand))]">20+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Expert freelance consultants and trainers</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Services: Same background, with top border -->
	<section id="services" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Our Services</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight">Comprehensive Solutions for Every Stage</h2>
				<p class="mt-4 text-base text-[hsl(var(--muted-foreground))]">
					From initial compliance assessments to full-scale certification support, we provide end-to-end services tailored to your needs.
				</p>
			</div>

			<div class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				{services.map((service, index) => (
					<a 
						href={`/services/${service.id}`}
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] p-8 transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						{/* Glow effect on hover */}
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						
						{/* Icon container with animated background */}
						<div class="relative">
							<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[hsl(var(--brand))] to-[hsl(var(--brand))]/70 text-[hsl(var(--brand-foreground))] flex items-center justify-center text-xl font-bold transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 shadow-lg shadow-[hsl(var(--brand))]/20">
								{service.icon.charAt(0)}
							</div>
							{/* Subtle line connecting icon */}
							<div class="absolute -bottom-2 left-7 h-px w-0 bg-gradient-to-r from-[hsl(var(--brand))] to-transparent transition-all duration-500 group-hover:w-8" />
						</div>
						
						{/* Title with hover color transition */}
						<h3 class="relative mt-6 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
							{service.title}
						</h3>
						
						{/* Description */}
						<p class="relative mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
							{service.summary}
						</p>
						
						{/* Read more link with arrow animation */}
						<div class="relative mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
							<span class="transition-transform duration-300 group-hover:translate-x-1">Read more</span>
							<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Projects: Same background, with top border -->
	<section id="projects" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
				<div>
					<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Featured Work</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight">Projects That Drive Impact</h2>
				</div>
				<a href="/projects" class="inline-flex btn btn-secondary sm:self-auto">View all projects</a>
			</div>

			<div id="projectsBanner" class="hidden mb-6 p-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm text-center">
				<span class="font-semibold">Hey you should really give it a taught</span>
			</div>
			<div id="projectsGrid" class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				{projects.length > 0 ? projects.map((project, index) => (
					<div
						class={`group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2 ${index >= 2 ? 'md:hidden lg:flex' : ''}`}
					>
						{/* Glow effect on hover */}
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						
						{/* Project thumbnail */}
						<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
							{project.imageUrl ? (
								<img src={project.imageUrl} alt={project.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
							) : (
								<div class="text-6xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📁</div>
							)}
							{/* Overlay gradient on hover */}
							<div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand))]/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
						</div>
						
						<div class="relative p-6 flex flex-col flex-grow">
							<p class="text-xs font-medium text-[hsl(var(--brand))] uppercase tracking-wide">{project.client}</p>
							<h3 class="mt-2 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
								{project.title}
							</h3>
							<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
								{project.description}
							</p>
						</div>
					</div>
				)) : (
					<>
						<div class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2">
							<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
							<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
								<div class="text-6xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📁</div>
								<div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand))]/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
							</div>
							<div class="relative p-6 flex flex-col flex-grow">
								<p class="text-xs font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Sidama Coffee Farmers Cooperative Union</p>
								<h3 class="mt-2 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
									GLOBALG.A.P Certification for Sidama Coffee Cooperative
								</h3>
								<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
									Implemented comprehensive GLOBALG.A.P certification program for 2,400 smallholder coffee farmers, enabling access to premium European markets.
								</p>
							</div>
						</div>
						<div class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2">
							<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
							<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
								<div class="text-6xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📁</div>
								<div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand))]/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
							</div>
							<div class="relative p-6 flex flex-col flex-grow">
								<p class="text-xs font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Ethiopian Sesame Exporters Association</p>
								<h3 class="mt-2 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
									Sesame Export Quality Improvement Program
								</h3>
								<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
									Established quality control systems and export documentation processes for major sesame exporters targeting Middle Eastern and Asian markets.
								</p>
							</div>
						</div>
						<div class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2">
							<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
							<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
								<div class="text-6xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📁</div>
								<div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand))]/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
							</div>
							<div class="relative p-6 flex flex-col flex-grow">
								<p class="text-xs font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Green Earth Spices PLC</p>
								<h3 class="mt-2 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
									Organic Certification Transition for Spice Exporters
								</h3>
								<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
									Guided organic certification transition for turmeric and ginger exporters, including farm mapping, documentation, and EU organic compliance.
								</p>
							</div>
						</div>
					</>
				)}
			</div>
		</div>
	</section>

	<!-- Testimonials: Same background, with top border -->
	<section id="testimonials" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Testimonials</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight">What Our Clients Say</h2>
				<p class="mt-4 text-base text-[hsl(var(--muted-foreground))]">
					Trusted by agribusinesses across Ethiopia and East Africa.
				</p>
			</div>

			<div class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
