		</div>
	</section>
</Layout>

<script>
	const form = document.getElementById('contactForm') as HTMLFormElement;
	const formFields = document.getElementById('formFields');
	const formSuccess = document.getElementById('formSuccess');
	const formError = document.getElementById('formError');
	const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

	// Validation elements
	const nameInput = document.getElementById('name') as HTMLInputElement;
	const emailInput = document.getElementById('email') as HTMLInputElement;
	const phoneInput = document.getElementById('phone') as HTMLInputElement;
	const countryCodeSelect = document.getElementById('countryCode') as HTMLSelectElement;
	const messageInput = document.getElementById('message') as HTMLTextAreaElement;
	
	const nameError = document.getElementById('nameError');
	const emailError = document.getElementById('emailError');
	const phoneError = document.getElementById('phoneError');
	const messageError = document.getElementById('messageError');
	const messageCount = document.getElementById('messageCount');
	const messageProgress = document.getElementById('messageProgress');

	// Country Picker
	const countryPickerBtn = document.getElementById('countryPickerBtn');
	const countryDropdown = document.getElementById('countryDropdown');
	const countryList = document.getElementById('countryList');
	const countrySearch = document.getElementById('countrySearch');
	const selectedFlag = document.getElementById('selectedFlag');
	const selectedCode = document.getElementById('selectedCode');
	const countryCodeInput = document.getElementById('countryCode') as HTMLInputElement;
	const countryBackdrop = document.getElementById('countryBackdrop');

	const countries = [
		{ code: '+251', flag: '🇪🇹', name: 'Ethiopia' },
		{ code: '+1', flag: '🇺🇸', name: 'United States' },
		{ code: '+44', flag: '🇬🇧', name: 'United Kingdom' },
		{ code: '+49', flag: '🇩🇪', name: 'Germany' },
		{ code: '+33', flag: '🇫🇷', name: 'France' },
		{ code: '+39', flag: '🇮🇹', name: 'Italy' },
		{ code: '+31', flag: '🇳🇱', name: 'Netherlands' },
		{ code: '+32', flag: '🇧🇪', name: 'Belgium' },
		{ code: '+46', flag: '🇸🇪', name: 'Sweden' },
		{ code: '+47', flag: '🇳🇴', name: 'Norway' },
		{ code: '+45', flag: '🇩🇰', name: 'Denmark' },
		{ code: '+358', flag: '🇫🇮', name: 'Finland' },
		{ code: '+41', flag: '🇨🇭', name: 'Switzerland' },
		{ code: '+43', flag: '🇦🇹', name: 'Austria' },
		{ code: '+34', flag: '🇪🇸', name: 'Spain' },
		{ code: '+351', flag: '🇵🇹', name: 'Portugal' },
		{ code: '+27', flag: '🇿🇦', name: 'South Africa' },
		{ code: '+254', flag: '🇰🇪', name: 'Kenya' },
		{ code: '+255', flag: '🇹🇿', name: 'Tanzania' },
		{ code: '+256', flag: '🇺🇬', name: 'Uganda' },
		{ code: '+250', flag: '🇷🇼', name: 'Rwanda' },
		{ code: '+253', flag: '🇩🇯', name: 'Djibouti' },
		{ code: '+252', flag: '🇸🇴', name: 'Somalia' },
		{ code: '+249', flag: '🇸🇩', name: 'Sudan' },
		{ code: '+20', flag: '🇪🇬', name: 'Egypt' },
		{ code: '+212', flag: '🇲🇦', name: 'Morocco' },
		{ code: '+216', flag: '🇹🇳', name: 'Tunisia' },
		{ code: '+213', flag: '🇩🇿', name: 'Algeria' },
		{ code: '+218', flag: '🇱🇾', name: 'Libya' },
		{ code: '+234', flag: '🇳🇬', name: 'Nigeria' },
		{ code: '+233', flag: '🇬🇭', name: 'Ghana' },
		{ code: '+225', flag: '🇨🇮', name: 'Ivory Coast' },
		{ code: '+221', flag: '🇸🇳', name: 'Senegal' },
		{ code: '+91', flag: '🇮🇳', name: 'India' },
		{ code: '+86', flag: '🇨🇳', name: 'China' },
		{ code: '+81', flag: '🇯🇵', name: 'Japan' },
		{ code: '+82', flag: '🇰🇷', name: 'South Korea' },
		{ code: '+61', flag: '🇦🇺', name: 'Australia' },
	];

	function renderCountryList(filter = '') {
		if (!countryList) return;
		const filtered = countries.filter(c => 
			c.name.toLowerCase().includes(filter.toLowerCase()) || 
			c.code.includes(filter)
		);
		
		if (filtered.length === 0) {
			countryList.innerHTML = `
				<div class="px-4 py-8 text-center text-[hsl(var(--muted-foreground))]">
					<svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					<p class="text-sm">No countries found</p>
				</div>
			`;
			return;
		}
		
		countryList.innerHTML = filtered.map((country, index) => `
			<button type="button" class="w-full px-3 py-3 flex items-center gap-4 hover:bg-[hsl(var(--brand))]/10 rounded-xl transition-all duration-200 text-left group ${index === 0 ? 'bg-[hsl(var(--brand))]/5' : ''}" data-code="${country.code}" data-flag="${country.flag}">
				<span class="text-3xl group-hover:scale-110 transition-transform">${country.flag}</span>
				<div class="flex-1 min-w-0">
					<span class="text-sm font-semibold text-[hsl(var(--foreground))] block truncate">${country.name}</span>
					<span class="text-xs text-[hsl(var(--muted-foreground))]">${country.code}</span>
				</div>
				${country.code === '+251' ? '<span class="text-xs font-medium text-[hsl(var(--brand))] bg-[hsl(var(--brand))]/10 px-2 py-0.5 rounded-full">Default</span>' : ''}
			</button>
		`).join('');

		// Add click handlers
		countryList.querySelectorAll('button').forEach(btn => {
			btn.addEventListener('click', () => {
				const code = btn.dataset.code || '+251';
				const flag = btn.dataset.flag || '🇪🇹';
				if (selectedFlag) selectedFlag.textContent = flag;
				if (selectedCode) selectedCode.textContent = code;
				if (countryCodeInput) countryCodeInput.value = code;
				closeDropdown();
			});
		});
	}

	function openDropdown() {
		if (countryBackdrop) {
			countryBackdrop.classList.remove('hidden');
			setTimeout(() => countryBackdrop?.classList.remove('opacity-0'), 10);
		}
		if (countryDropdown) {
			countryDropdown.classList.remove('hidden');
			countrySearch?.focus();
		}
	}

	function closeDropdown() {
		if (countryBackdrop) {
			countryBackdrop.classList.add('opacity-0');
			setTimeout(() => countryBackdrop?.classList.add('hidden'), 300);
		}
		if (countryDropdown) {
			countryDropdown.classList.add('hidden');
		}
	}

	// Initialize country list
	renderCountryList();

	// Toggle dropdown
	countryPickerBtn?.addEventListener('click', (e) => {
		e.stopPropagation();
		if (countryDropdown?.classList.contains('hidden')) {
			openDropdown();
		} else {
			closeDropdown();
		}
	});

	// Close on backdrop click
	countryBackdrop?.addEventListener('click', () => {
		closeDropdown();
	});

	// Search functionality
	countrySearch?.addEventListener('input', () => {
		renderCountryList(countrySearch.value);
	});

	// Close dropdown when clicking outside
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (!target.closest('#countryPicker')) {
			closeDropdown();
		}
	});

	// Close on escape key
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') {
			closeDropdown();
		}
	});

	// Validation functions
	function validateName(name: string): { valid: boolean; error: string } {
		if (!name || name.trim().length === 0) {
			return { valid: false, error: 'Name is required' };
		}
		if (name.length > 50) {
			return { valid: false, error: 'Name must be 50 characters or less' };
		}
		// Only letters and spaces allowed (no numbers or special characters)
		const nameRegex = /^[a-zA-Z\s]+$/;
		if (!nameRegex.test(name)) {
			return { valid: false, error: 'Name can only contain letters and spaces' };
		}
		return { valid: true, error: '' };
	}

	function validateEmail(email: string): { valid: boolean; error: string } {
		if (!email || email.trim().length === 0) {
			return { valid: false, error: 'Email is required' };
		}
		const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
		if (!emailRegex.test(email)) {
			return { valid: false, error: 'Please enter a valid email address' };
		}
		return { valid: true, error: '' };
	}

	function validatePhone(phone: string): { valid: boolean; error: string } {
		if (!phone || phone.trim().length === 0) {
			return { valid: false, error: 'Phone number is required' };
		}
		// Only digits allowed
		const phoneRegex = /^\d+$/;
		if (!phoneRegex.test(phone)) {
			return { valid: false, error: 'Phone number can only contain numbers' };
		}
		if (phone.length !== 10) {
			return { valid: false, error: 'Phone number must be exactly 10 digits' };
		}
		return { valid: true, error: '' };
	}

	function validateMessage(message: string): { valid: boolean; error: string } {
		if (!message || message.trim().length === 0) {
			return { valid: false, error: 'Message is required' };
		}
		if (message.length > 500) {
			return { valid: false, error: 'Message must be 500 characters or less' };
		}
		return { valid: true, error: '' };
	}

	// Real-time validation
	nameInput?.addEventListener('input', () => {
		const result = validateName(nameInput.value);
		if (!result.valid && nameInput.value.length > 0) {
			nameError?.classList.remove('hidden');
			nameError!.textContent = result.error;
			nameInput.classList.add('border-red-500');
			nameInput.classList.remove('border-[hsl(var(--border))]');
		} else {
			nameError?.classList.add('hidden');
			nameInput.classList.remove('border-red-500');
			nameInput.classList.add('border-[hsl(var(--border))]');
		}
	});

	emailInput?.addEventListener('input', () => {
		const result = validateEmail(emailInput.value);
		if (!result.valid && emailInput.value.length > 0) {
			emailError?.classList.remove('hidden');
			emailError!.textContent = result.error;
			emailInput.classList.add('border-red-500');
			emailInput.classList.remove('border-[hsl(var(--border))]');
		} else {
			emailError?.classList.add('hidden');
			emailInput.classList.remove('border-red-500');
			emailInput.classList.add('border-[hsl(var(--border))]');
		}
	});

	// Phone number input restriction - only allow numbers
	phoneInput?.addEventListener('input', () => {
		// Remove any non-digit characters
		phoneInput.value = phoneInput.value.replace(/\D/g, '');
		
		// Limit to 10 digits
		if (phoneInput.value.length > 10) {
			phoneInput.value = phoneInput.value.slice(0, 10);
		}
		
		const result = validatePhone(phoneInput.value);
		if (!result.valid && phoneInput.value.length > 0) {
			phoneError?.classList.remove('hidden');
			phoneError!.textContent = result.error;
			phoneInput.classList.add('border-red-500');
			phoneInput.classList.remove('border-[hsl(var(--border))]');
		} else {
			phoneError?.classList.add('hidden');
			phoneInput.classList.remove('border-red-500');
			phoneInput.classList.add('border-[hsl(var(--border))]');
		}
	});

	// Message character counter
	messageInput?.addEventListener('input', () => {
		const count = messageInput.value.length;
		const percentage = (count / 500) * 100;
		
		if (messageCount) {
			messageCount.textContent = `${count} / 500`;
			if (count > 450) {
				messageCount.classList.add('text-red-500');
				messageCount.classList.remove('text-[hsl(var(--muted-foreground))]');
			} else {
				messageCount.classList.remove('text-red-500');
				messageCount.classList.add('text-[hsl(var(--muted-foreground))]');
			}
		}
		
		if (messageProgress) {
			messageProgress.style.width = `${percentage}%`;
			if (count > 450) {
				messageProgress.classList.remove('bg-[hsl(var(--brand))]');
				messageProgress.classList.add('bg-red-500');
			} else {
				messageProgress.classList.add('bg-[hsl(var(--brand))]');
				messageProgress.classList.remove('bg-red-500');
			}
		}
		
		const result = validateMessage(messageInput.value);
		if (!result.valid && messageInput.value.length > 0) {
			messageError?.classList.remove('hidden');
			messageError!.textContent = result.error;
			messageInput.classList.add('border-red-500');
			messageInput.classList.remove('border-[hsl(var(--border))]');
		} else {
			messageError?.classList.add('hidden');
			messageInput.classList.remove('border-red-500');
			messageInput.classList.add('border-[hsl(var(--border))]');
		}
	});

	// WordPress Contact Form 7 REST API endpoint
	const CF7_ENDPOINT = '/wp-json/contact-form-7/v1/contact-forms/123/feedback';

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		// Validate all fields
		const nameResult = validateName(nameInput?.value || '');
		const emailResult = validateEmail(emailInput?.value || '');
		const phoneResult = validatePhone(phoneInput?.value || '');
		const messageResult = validateMessage(messageInput?.value || '');

		// Show errors if any
		if (!nameResult.valid) {
			nameError?.classList.remove('hidden');
			nameError!.textContent = nameResult.error;
			nameInput?.classList.add('border-red-500');
			nameInput?.classList.remove('border-[hsl(var(--border))]');
			nameInput?.focus();
			return;
		}

		if (!emailResult.valid) {
			emailError?.classList.remove('hidden');
			emailError!.textContent = emailResult.error;
			emailInput?.classList.add('border-red-500');
			emailInput?.classList.remove('border-[hsl(var(--border))]');
			emailInput?.focus();
			return;
		}

		if (!phoneResult.valid) {
			phoneError?.classList.remove('hidden');
			phoneError!.textContent = phoneResult.error;
			phoneInput?.classList.add('border-red-500');
			phoneInput?.classList.remove('border-[hsl(var(--border))]');
			phoneInput?.focus();
			return;
		}

		if (!messageResult.valid) {
			messageError?.classList.remove('hidden');
			messageError!.textContent = messageResult.error;
			messageInput?.classList.add('border-red-500');
			messageInput?.classList.remove('border-[hsl(var(--border))]');
			messageInput?.focus();
			return;
		}
		
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Sending...';
		}

		// Combine country code with phone number
		const fullPhone = `${countryCodeSelect?.value || '+251'} ${phoneInput?.value || ''}`;

		const formData = new FormData(form);
		formData.set('your-phone', fullPhone);

		try {
			const response = await fetch(CF7_ENDPOINT, {
				method: 'POST',
				body: formData,
			});

			const result = await response.json();

			if (result.status === 'mail_sent') {
				formFields?.classList.add('hidden');
				formSuccess?.classList.remove('hidden');
				formError?.classList.add('hidden');
			} else {
				throw new Error(result.message || 'Failed to send message');
			}
		} catch (error) {
			if (formError) {
				formError.textContent = error instanceof Error ? error.message : 'Something went wrong. Please try again or email us directly.';
				formError.classList.remove('hidden');
			}
		} finally {
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.innerHTML = `<span>Send message</span><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`;
			}
		}
	});
</script>
