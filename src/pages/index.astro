---
import Layout from '../layouts/Layout.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';
import { listPosts } from '../lib/wp';

const { posts: latestPosts } = await listPosts({ perPage: 3 }).catch(() => ({ posts: [] }));

const contactInfo = {
	email: 'info@mekanconsultancy.com',
	phone: '+251 911 234 567'
};

const services = [
	{
		id: 'quality-assurance',
		title: 'Quality Assurance & Regulatory Compliance',
		summary: 'Food safety systems, private label standards, EU export readiness, and benchmarking.',
		icon: 'Shield'
	},
	{
		id: 'agribusiness-development',
		title: 'Agribusiness Development & Strategic Growth',
		summary: 'Scaling strategies, SME business plans, performance monitoring, and value chain development.',
		icon: 'TrendingUp'
	},
	{
		id: 'agricultural-productivity',
		title: 'Agricultural Productivity & Sustainability',
		summary: 'GAP implementation, postharvest safety, IPM, and integrated farm management.',
		icon: 'Leaf'
	},
	{
		id: 'food-systems',
		title: 'Food Systems & Climate Resilience',
		summary: 'Diagnostics, policy strategy, climate risk management, and nutrition programming.',
		icon: 'Globe'
	},
	{
		id: 'capacity-building',
		title: 'Capacity Building & Training',
		summary: 'Practical skills transfer, field-level training, and organizational development.',
		icon: 'Users'
	},
	{
		id: 'certification-support',
		title: 'Certification & Audit Support',
		summary: 'Third-party representation, gap analysis, and preparation for GlobalG.A.P., BRCGS, IFS.',
		icon: 'Award'
	}
];

const projects = [
	{
		id: 1,
		title: 'Ethiopian Coffee Export Compliance',
		client: 'Regional Cooperative Union',
		description: 'Achieved GlobalG.A.P. and organic certification for 2,000+ smallholder farmers.',
		image: null
	},
	{
		id: 2,
		title: 'EU Market Entry Strategy',
		client: 'Agro-Processing SME',
		description: 'End-to-end compliance framework enabling first export to European markets.',
		image: null
	},
	{
		id: 3,
		title: 'Climate Resilience Program',
		client: 'International NGO',
		description: 'Food systems diagnostics and risk management training across 15 districts.',
		image: null
	}
];

function formatDate(dateStr: string) {
	return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function stripHtml(html: string) {
	return html.replace(/<[^>]*>/g, '').substring(0, 120) + '...';
}
---

<Layout overlayNav>
	<!-- Hero: Background image slideshow with Partners -->
	<section id="home" class="relative bg-[hsl(var(--brand))] text-[hsl(var(--brand-foreground))] overflow-hidden">
		{/* Background Image Slideshow */}
		<div class="absolute inset-0 z-0">
			{[1, 2, 3, 4, 5].map((num, index) => (
				<div
					class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000 ease-in-out hero-slide"
					style={`
						background-image: url('/hero/${num}.jpg');
						opacity: ${index === 0 ? '1' : '0'};
						animation: heroFade ${5 * 8}s infinite;
						animation-delay: ${index * 8}s;
					`}
				/>
			))}
			{/* Lighter overlay for more visible images - reduced opacity */}
			<div class="absolute inset-0 bg-gradient-to-r from-[hsl(var(--brand))]/40 via-[hsl(var(--brand))]/25 to-[hsl(var(--brand))]/15" />
		</div>

		<div class="container pb-12 pt-32 md:pt-40 relative z-10" data-aos="fade-up" data-aos-duration="800">
			<div class="max-w-3xl">
				<p class="text-sm font-medium tracking-wide text-[hsl(var(--brand-foreground))]/70 uppercase">
					Quality Management & Training PLC
				</p>
				<h1 class="mt-6 text-balance text-4xl font-semibold tracking-tight md:text-5xl lg:text-6xl">
					Empowering Sustainable Growth in Global Agribusiness
				</h1>
				<p class="mt-6 max-w-lg text-pretty text-lg leading-relaxed text-[hsl(var(--brand-foreground))]/80">
					Comprehensive consulting, compliance, and strategic solutions for a resilient future.
				</p>
				<div class="mt-10 flex flex-wrap gap-4">
					<a href="#contact" class="btn btn-brand">Request a consultation</a>
					<a href="#services" class="btn btn-brand-outline">Explore services</a>
				</div>
			</div>
		</div>

		{/* Partners Marquee - now part of hero with same background */}
		<div class="relative z-10 py-12">
			<PartnersMarquee />
		</div>

		<style>
			@keyframes heroFade {
				0%, 18% { opacity: 1; }
				20%, 98% { opacity: 0; }
				100% { opacity: 1; }
			}
		</style>
	</section>

	<!-- About: Same background, with top border -->
	<section id="about" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="grid gap-12 md:grid-cols-12 md:items-center">
				<!-- Text content - now on LEFT -->
				<div class="md:col-span-7">
					<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">About Us</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight">Your Partner in Agricultural Excellence</h2>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Mekan Quality Management & Training PLC is a leading consultancy firm specializing in agricultural quality assurance, regulatory compliance, and sustainable agribusiness development. We bridge the gap between local agricultural practices and global market standards.
					</p>
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						Our team of experts combines deep technical knowledge with practical field experience to deliver solutions that drive real results—from farm certification to international market entry.
					</p>
					<div class="mt-8">
						<a href="/about" class="btn btn-primary">Explore more about us →</a>
					</div>
				</div>
				<!-- Stats - now on RIGHT -->
				<div class="md:col-span-5">
					<div class="card p-8">
						<div class="text-4xl font-bold text-[hsl(var(--brand))]">15+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Years of experience in agribusiness consulting</p>
						<div class="mt-6 text-4xl font-bold text-[hsl(var(--brand))]">500+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Clients across Ethiopia and East Africa</p>
						<div class="mt-6 text-4xl font-bold text-[hsl(var(--brand))]">50+</div>
						<p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">Certifications achieved annually</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Services: Same background, with top border -->
	<section id="services" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Our Services</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight">Comprehensive Solutions for Every Stage</h2>
				<p class="mt-4 text-base text-[hsl(var(--muted-foreground))]">
					From initial compliance assessments to full-scale certification support, we provide end-to-end services tailored to your needs.
				</p>
			</div>

			<div class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				{services.map((service, index) => (
					<a 
						href={`/services/${service.id}`}
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] p-8 transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						{/* Glow effect on hover */}
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						
						{/* Icon container with animated background */}
						<div class="relative">
							<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[hsl(var(--brand))] to-[hsl(var(--brand))]/70 text-[hsl(var(--brand-foreground))] flex items-center justify-center text-xl font-bold transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 shadow-lg shadow-[hsl(var(--brand))]/20">
								{service.icon.charAt(0)}
							</div>
							{/* Subtle line connecting icon */}
							<div class="absolute -bottom-2 left-7 h-px w-0 bg-gradient-to-r from-[hsl(var(--brand))] to-transparent transition-all duration-500 group-hover:w-8" />
						</div>
						
						{/* Title with hover color transition */}
						<h3 class="relative mt-6 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
							{service.title}
						</h3>
						
						{/* Description */}
						<p class="relative mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
							{service.summary}
						</p>
						
						{/* Read more link with arrow animation */}
						<div class="relative mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
							<span class="transition-transform duration-300 group-hover:translate-x-1">Read more</span>
							<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Projects: Same background, with top border -->
	<section id="projects" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="flex items-end justify-between gap-6">
				<div>
					<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Featured Work</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight">Projects That Drive Impact</h2>
				</div>
				<a href="/projects" class="hidden md:inline-flex btn btn-secondary">View all projects</a>
			</div>

			<div class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				{projects.map((project, index) => (
					<a 
						href={`/projects/${project.id}`}
						class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] overflow-hidden transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2"
					>
						{/* Glow effect on hover */}
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						
						{/* Project thumbnail */}
						<div class="relative h-48 bg-gradient-to-br from-[hsl(var(--muted))] to-[hsl(var(--card))] flex items-center justify-center overflow-hidden">
							<div class="text-6xl text-[hsl(var(--muted-foreground))]/30 transition-transform duration-500 group-hover:scale-110">📁</div>
							{/* Overlay gradient on hover */}
							<div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--brand))]/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
						</div>
						
						<div class="relative p-6 flex flex-col flex-grow">
							<p class="text-xs font-medium text-[hsl(var(--brand))] uppercase tracking-wide">{project.client}</p>
							<h3 class="mt-2 text-lg font-semibold text-[hsl(var(--foreground))] transition-colors duration-300 group-hover:text-[hsl(var(--brand))]">
								{project.title}
							</h3>
							<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
								{project.description}
							</p>
							<div class="mt-6 flex items-center gap-2 text-sm font-medium text-[hsl(var(--brand))] transition-all duration-300">
								<span class="transition-transform duration-300 group-hover:translate-x-1">Read case study</span>
								<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Testimonials: Same background, with top border -->
	<section id="testimonials" class="section bg-[hsl(var(--background))] border-t border-[hsl(var(--border))]">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Testimonials</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight">What Our Clients Say</h2>
				<p class="mt-4 text-base text-[hsl(var(--muted-foreground))]">
					Trusted by agribusinesses across Ethiopia and East Africa.
				</p>
			</div>

			<div class="mt-16 grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				<div class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] p-8 transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2">
					{/* Glow effect */}
					<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
					<div class="relative">
						<div class="flex items-center gap-1 text-yellow-500">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						</div>
						<p class="mt-4 text-sm leading-relaxed text-[hsl(var(--muted-foreground))]">
								"Mekan helped us achieve GlobalG.A.P. certification in record time. Their expertise in food safety systems transformed our entire operation."
							</p>
							<div class="mt-6 flex items-center gap-3">
								<div class="w-11 h-11 rounded-full bg-gradient-to-br from-[hsl(var(--brand))] to-[hsl(var(--brand))]/70 text-[hsl(var(--brand-foreground))] flex items-center justify-center font-semibold text-sm shadow-lg shadow-[hsl(var(--brand))]/20">AT</div>
								<div>
									<p class="text-sm font-medium text-[hsl(var(--foreground))]">Abebe Tadesse</p>
									<p class="text-xs text-[hsl(var(--muted-foreground))]">Managing Director, Sunrise Coffee Cooperative</p>
								</div>
							</div>
						</div>
					</div>

					<div class="group relative flex flex-col bg-gradient-to-br from-[hsl(var(--card))] to-[hsl(var(--background))] rounded-2xl border border-[hsl(var(--border))] p-8 transition-all duration-500 ease-out hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:shadow-[hsl(var(--brand))]/10 hover:border-[hsl(var(--brand))]/50 hover:-translate-y-2">
						<div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[hsl(var(--brand))]/0 via-[hsl(var(--brand))]/0 to-[hsl(var(--brand))]/0 opacity-0 transition-all duration-500 group-hover:from-[hsl(var(--brand))]/5 group-hover:via-[hsl(var(--brand))]/3 group-hover:to-[hsl(var(--brand))]/5 group-hover:opacity-100" />
						<div class="relative">
							<div class="flex items-center gap-1 text-yellow-500">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
