	'investment-advisory': {
		title: 'Private Sector & Investment Advisory',
		description: 'Turning data into decisive action for investors and stakeholders.',
		images: [
			'/gallery/photo_41.jpg', '/gallery/photo_42.jpg', '/gallery/photo_43.jpg',
			'/gallery/photo_44.jpg', '/gallery/photo_45.jpg', '/gallery/photo_46.jpg',
			'/gallery/photo_47.jpg', '/gallery/photo_48.jpg', '/gallery/photo_49.jpg',
			'/gallery/photo_50.jpg', '/gallery/photo_51.jpg', '/gallery/photo_52.jpg',
			'/gallery/photo_53.jpg', '/gallery/photo_54.jpg'
		],
		about: [
			'For investors and private sector entities, we serve as the analytical bridge between capital and agricultural success through data-driven insights.',
			'We support organizations with planning, MEL, modelling, and implementation support—helping projects deliver measurable results and value for money.'
		],
		features: [
			'Supply Chain & Logistics Optimization (data modelling)',
