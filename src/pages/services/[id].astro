};

const deliveryApproach = [
	{
		title: 'Strategic Consultation',
		description: 'High-level advisory for executive decision-making.'
	},
	{
		title: 'Capacity Building & Training',
		description: 'Practical, field-level skills transfer.'
	},
	{
		title: 'Coaching & Mentorship',
		description: 'Long-term professional development for internal stakeholders.'
	},
	{
		title: 'Research & Evaluation',
		description: 'Data-driven insights and rigorous project assessments.'
	},
	{
		title: 'Gap Analysis & Risk Audits',
		description: 'Identifying operational vulnerabilities before they impact the bottom line.'
	},
	{
		title: 'Document Preparation',
		description: 'Authoring technical manuals and SOPs required for global audits.'
	},
	{
		title: 'Third-Party Representation',
		description: 'Acting as your technical advocate during rigorous international certification audits.'
	}
];

const { id } = Astro.params;
const service = id && services[id as keyof typeof services];

if (!service) {
	return Astro.redirect('/#services');
}

/**
 * Service Schema.org Structured Data (JSON-LD)
 * 
 * Implements schema.org/Service markup to help search engines understand
 * this page represents a professional consulting service. This enables:
 * - Rich snippets in search results
 * - Service-specific SEO enhancements
 * - Better visibility for "consulting Ethiopia" searches
 * 
 * @see https://schema.org/Service
 */
const requestOrigin = Astro.request?.url ? new URL(Astro.request.url).origin : '';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || requestOrigin).replace(/\/$/, '');
const pageUrl = siteUrl ? new URL(Astro.url.pathname, siteUrl).toString() : Astro.url.pathname;

const serviceLd = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: service.title,
	description: service.description,
	url: pageUrl,
	provider: {
		'@type': 'Organization',
		name: 'Mekan PLC',
		url: siteUrl || undefined,
		logo: siteUrl ? new URL('/logo1.2.png', siteUrl).toString() : '/logo1.2.png',
		contactPoint: {
			'@type': 'ContactPoint',
			contactType: 'sales',
			email: 'biniam@mekanplc.com',
			telephone: '+251911454671',
			availableLanguage: ['English']
		}
	},
	areaServed: {
		'@type': 'Place',
		name: 'Ethiopia'
	},
	serviceType: 'Consulting'
};

---

<Layout title={service.title} overlayNav>
	<script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
	{/* Hero with logo background */}
	<section class="relative text-white overflow-hidden">
		<div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/logo.png');"></div>
		<div class="absolute inset-0 bg-[#0F2C59]/90"></div>
		<div class="relative container pt-32 pb-24">
			{/* Breadcrumb */}
			<nav class="flex items-center gap-2 text-sm text-white/70 mb-6">
				<a href="/" class="hover:text-white transition-colors flex items-center gap-1">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
					</svg>
					Home
				</a>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
				<a href="/#services" class="hover:text-white transition-colors">Services</a>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
				<span class="text-white font-medium whitespace-nowrap overflow-x-auto max-w-[200px] sm:max-w-none scrollbar-hide">{service.title}</span>
			</nav>
			<h1 class="text-xl sm:text-2xl md:text-4xl font-semibold tracking-tight max-w-3xl whitespace-nowrap overflow-x-auto scrollbar-hide">
				{service.title}
			</h1>
			<p class="mt-4 text-lg text-white/80 max-w-2xl">
				{service.description}
			</p>
		</div>
	</section>

	{/* Detailed Description */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="max-w-3xl">
				<h2 class="text-2xl font-semibold tracking-tight text-[hsl(var(--foreground))]">About this service</h2>
				{(service.about ?? []).map((para) => (
					<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
						{para}
					</p>
				))}
			</div>
		</div>
	</section>

	{/* Features Section */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="grid gap-12 lg:grid-cols-3">
				<div class="lg:col-span-2">
					<h2 class="text-2xl font-semibold tracking-tight text-[hsl(var(--foreground))]">What we offer</h2>
					<div class="mt-6 grid gap-4 sm:grid-cols-2">
						{service.features.map((feature) => (
							<div class="flex items-start gap-3 p-4 rounded-xl bg-[hsl(var(--card))] border-l-4 border-[#0F2C59] dark:border-[#7EA2CE]">
								<div class="w-6 h-6 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] text-white flex items-center justify-center text-sm flex-shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
									</svg>
								</div>
								<span class="text-sm text-slate-700 dark:text-white/80">{feature}</span>
							</div>
						))}
					</div>
				</div>
				<div>
					<div class="relative rounded-2xl bg-[hsl(var(--card))] p-6 sticky top-24 overflow-hidden">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE]">Key Benefits</h3>
							<ul class="mt-4 space-y-3">
								{service.benefits.map((benefit) => (
									<li class="flex items-start gap-2 text-sm text-slate-600 dark:text-white/70">
										<span class="text-[#0F2C59] dark:text-[#7EA2CE] font-bold">→</span>
										<span>{benefit}</span>
									</li>
								))}
							</ul>
							<a href="/#contact" class="btn btn-primary w-full mt-6 text-center inline-flex items-center justify-center gap-2">
								Get started
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
							<div class="mt-4 flex gap-2">
								<a href="tel:+251911454671" class="btn bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-white flex-1 text-center inline-flex items-center justify-center gap-1.5 py-2 px-2 text-xs sm:text-sm rounded-lg transition-colors whitespace-nowrap">
									<svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
									Call us
								</a>
								<a href="mailto:biniam@mekanplc.com" class="btn bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-white flex-1 text-center inline-flex items-center justify-center gap-1.5 py-2 px-2 text-xs sm:text-sm rounded-lg transition-colors whitespace-nowrap">
									<svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
									Email us
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-12">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Our delivery</p>
				<h2 class="mt-4 text-3xl font-semibold tracking-tight">Tailored delivery for diverse organizational needs</h2>
				<p class="mt-4 text-base text-[hsl(var(--muted-foreground))]">
					We don’t believe in one-size-fits-all solutions. Our methodology is flexible, ensuring that our expertise is integrated seamlessly into your existing operations.
				</p>
			</div>
			<div class="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-12">
				{/* First 4 cards - each takes 3 columns (4 x 3 = 12) */}
				{deliveryApproach.slice(0, 4).map((item) => (
					<div class="relative rounded-2xl bg-[hsl(var(--card))] p-6 overflow-hidden lg:col-span-3">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE]">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-white/80">{item.description}</p>
						</div>
					</div>
				))}
				{/* Last 3 cards - each takes 4 columns (3 x 4 = 12) */}
				{deliveryApproach.slice(4).map((item) => (
					<div class="relative rounded-2xl bg-[hsl(var(--card))] p-6 overflow-hidden lg:col-span-4">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE]">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-white/80">{item.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	{/* Our Work Gallery Section */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-8">
				<p class="text-sm font-medium text-[hsl(var(--brand))] uppercase tracking-wide">Portfolio</p>
				<h2 class="mt-3 text-3xl font-semibold tracking-tight text-[hsl(var(--foreground))]">Our Work</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))]">
					See real results from our {service.title.toLowerCase()} projects across Ethiopia.
				</p>
				<button 
					id="gallery-toggle"
					class="mt-6 inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] text-white font-medium hover:bg-[#0F2C59]/90 dark:hover:bg-[#7EA2CE]/90 hover:scale-105 active:scale-95 transition-all duration-300 shadow-lg hover:shadow-xl"
				>
					<span id="toggle-text">View our projects</span>
					<svg id="toggle-icon" class="w-5 h-5 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
			</div>
			
			{/* Expandable Gallery with smooth animation */}
			<div id="work-gallery" class="grid transition-all duration-700 ease-in-out overflow-hidden" style="grid-template-rows: 0fr; opacity: 0;">
				<div class="min-h-0">
					<div class="grid gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4 pb-2">
						{service.images?.map((img, index) => (
							<div class="group relative aspect-[4/3] rounded-xl overflow-hidden cursor-pointer bg-slate-200 dark:bg-[#1F2937]">
								<img 
									src={img} 
									alt={`${service.title} project ${index + 1}`}
									class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
									loading="lazy"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-[#0F2C59]/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
								<div class="absolute bottom-0 left-0 right-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
									<p class="text-white text-xs font-medium">Project {index + 1}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		const toggleBtn = document.getElementById('gallery-toggle');
		const gallery = document.getElementById('work-gallery');
		const toggleText = document.getElementById('toggle-text');
		const toggleIcon = document.getElementById('toggle-icon');
		let isOpen = false;

		toggleBtn?.addEventListener('click', () => {
			isOpen = !isOpen;
			if (isOpen) {
				gallery.style.gridTemplateRows = '1fr';
				gallery.style.opacity = '1';
				toggleText.textContent = 'Hide projects';
				toggleIcon.style.transform = 'rotate(180deg)';
			} else {
				gallery.style.gridTemplateRows = '0fr';
				gallery.style.opacity = '0';
				toggleText.textContent = 'View our projects';
				toggleIcon.style.transform = 'rotate(0deg)';
			}
		});
	</script>
</Layout>
