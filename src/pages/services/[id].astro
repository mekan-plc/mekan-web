---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
	const serviceIds = [
		'quality-assurance',
		'agribusiness-development',
		'agricultural-productivity',
		'food-systems',
		'capacity-building',
		'certification-support'
	];
	return serviceIds.map(id => ({ params: { id } }));
}

const services = {
	'quality-assurance': {
		title: 'Quality Assurance & Regulatory Compliance',
		description: 'Comprehensive food safety systems and regulatory compliance solutions for agribusinesses targeting global markets.',
		features: [
			'GlobalG.A.P. certification preparation and maintenance',
			'HACCP system implementation and training',
			'BRCGS and IFS private label standard compliance',
			'EU market entry readiness assessments',
			'CSR/ESG compliance and reporting',
			'OHS and environmental benchmarking',
			'Third-party audit representation',
			'Gap analysis and corrective action planning'
		],
		benefits: [
			'Access to premium international markets',
			'Reduced compliance risks and penalties',
			'Improved product quality and safety',
			'Enhanced brand reputation and trust',
			'Streamlined certification processes'
		]
	},
	'agribusiness-development': {
		title: 'Agribusiness Development & Strategic Growth',
		description: 'Strategic consulting to help agribusinesses scale operations, enter new markets, and achieve sustainable growth.',
		features: [
			'Scaling strategy development and implementation',
			'SME business plan development',
			'Performance monitoring systems',
			'Executive coaching and advisory',
			'Management capacity building',
			'Value chain development and optimization',
			'Market entry strategy and execution',
			'Partnership and network facilitation'
		],
		benefits: [
			'Increased operational efficiency',
			'Sustainable revenue growth',
			'Stronger market positioning',
			'Improved stakeholder management',
			'Access to new business opportunities'
		]
	},
	'agricultural-productivity': {
		title: 'Agricultural Productivity & Sustainability',
		description: 'Practical solutions for improving farm productivity while implementing sustainable agricultural practices.',
		features: [
			'Good Agricultural Practices (GAP) implementation',
			'Post-harvest safety and handling protocols',
			'Integrated Pest Management (IPM) programs',
			'Safe chemical use and management',
			'Soil and water conservation strategies',
			'Integrated Farm Management (IFM) systems',
			'Sustainable farming technique training',
			'Environmental impact assessments'
		],
		benefits: [
			'Higher crop yields and quality',
			'Reduced input costs and waste',
			'Improved environmental stewardship',
			'Better resource utilization',
			'Long-term farm viability'
		]
	},
	'food-systems': {
		title: 'Food Systems & Climate Resilience',
		description: 'Strategic approaches to building resilient food systems that can withstand climate challenges and market disruptions.',
		features: [
			'Food system diagnostics and assessments',
			'Policy and strategy development',
			'Climate risk management frameworks',
			'Nutrition-sensitive programming',
			'Supply chain resilience planning',
			'Adaptation strategy development',
			'Stakeholder engagement facilitation',
			'Impact monitoring and evaluation'
		],
		benefits: [
			'Enhanced climate adaptation capacity',
			'Improved food security outcomes',
			'Stronger institutional frameworks',
			'Better donor and investor confidence',
			'Measurable development impact'
		]
	},
	'capacity-building': {
		title: 'Capacity Building & Training',
		description: 'Comprehensive training programs and organizational development services to build internal capabilities.',
		features: [
			'Customized training program design',
			'Field-level skills transfer programs',
			'Organizational development consulting',
			'Leadership and management training',
			'Technical skills development',
			'Train-the-trainer programs',
			'Knowledge management systems',
			'Performance tracking tools'
		],
		benefits: [
			'Skilled and empowered workforce',
			'Improved organizational performance',
			'Sustainable internal expertise',
			'Better employee retention',
			'Knowledge preservation and transfer'
		]
	},
	'certification-support': {
		title: 'Certification & Audit Support',
		description: 'Expert guidance through the certification process from initial assessment to successful audit completion.',
		features: [
			'Pre-certification gap analysis',
			'Certification roadmap development',
			'Documentation and system setup',
			'Third-party audit representation',
			'Corrective action support',
			'Maintenance audit preparation',
			'Certification body liaison',
			'Continuous compliance monitoring'
		],
		benefits: [
			'Faster certification achievement',
			'First-time audit success',
			'Reduced certification costs',
			'Ongoing compliance assurance',
			'Audit-ready documentation'
		]
	}
};

const { id } = Astro.params;
const service = id && services[id as keyof typeof services];

if (!service) {
	return Astro.redirect('/services');
}
---

<Layout title={`${service.title} | Mekan`} overlayNav>
	{/* Hero with logo background */}
	<section class="relative text-white overflow-hidden">
		<div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/logo.png');"></div>
		<div class="absolute inset-0 bg-[#0F2C59]/90"></div>
		<div class="relative container pt-32 pb-24">
			{/* Breadcrumb */}
			<nav class="flex items-center gap-2 text-sm text-white/70 mb-6">
				<a href="/" class="hover:text-white transition-colors flex items-center gap-1">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
					</svg>
					Home
				</a>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
				<a href="/#services" class="hover:text-white transition-colors">Services</a>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
				<span class="text-white font-medium">{service.title}</span>
			</nav>
			<h1 class="text-3xl md:text-4xl font-semibold tracking-tight max-w-3xl">
				{service.title}
			</h1>
			<p class="mt-4 text-lg text-white/80 max-w-2xl">
				{service.description}
			</p>
		</div>
	</section>

	{/* Detailed Description */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="max-w-3xl">
				<h2 class="text-2xl font-semibold tracking-tight text-[hsl(var(--foreground))]">About this service</h2>
				<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
					Our {service.title.toLowerCase()} service is designed to help Ethiopian agribusinesses meet international standards and access premium global markets. We combine deep technical expertise with practical field experience to deliver solutions that work in local contexts. Whether you're a small cooperative or a large agro-processor, our tailored approach ensures you get the support you need to succeed.
				</p>
				<p class="mt-4 text-base leading-relaxed text-[hsl(var(--muted-foreground))]">
					With over 15 years of experience and 500+ clients served across East Africa, we understand the unique challenges facing Ethiopian agriculture. Our team works alongside you as true partners, providing hands-on guidance from initial assessment through implementation and beyond.
				</p>
			</div>
		</div>
	</section>

	{/* Features Section */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="grid gap-12 lg:grid-cols-3">
				<div class="lg:col-span-2">
					<h2 class="text-2xl font-semibold tracking-tight text-[hsl(var(--foreground))]">What we offer</h2>
					<div class="mt-6 grid gap-4 sm:grid-cols-2">
						{service.features.map((feature) => (
							<div class="flex items-start gap-3 p-4 rounded-xl bg-slate-100 dark:bg-[#1F2937] border-l-4 border-[#0F2C59] dark:border-[#7EA2CE]">
								<div class="w-6 h-6 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] text-white flex items-center justify-center text-sm flex-shrink-0">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
									</svg>
								</div>
								<span class="text-sm text-slate-700 dark:text-white/80">{feature}</span>
							</div>
						))}
					</div>
				</div>
				<div>
					<div class="relative rounded-2xl bg-slate-100 dark:bg-[#1F2937] p-6 sticky top-24 overflow-hidden">
						<div class="absolute left-0 top-0 bottom-0 w-1 bg-[#0F2C59] dark:bg-[#7EA2CE]"></div>
						<div class="relative">
							<h3 class="text-lg font-semibold text-[#0F2C59] dark:text-[#7EA2CE]">Key Benefits</h3>
							<ul class="mt-4 space-y-3">
								{service.benefits.map((benefit) => (
									<li class="flex items-start gap-2 text-sm text-slate-600 dark:text-white/70">
										<span class="text-[#0F2C59] dark:text-[#7EA2CE] font-bold">→</span>
										<span>{benefit}</span>
									</li>
								))}
							</ul>
							<a href="/#contact" class="btn btn-primary w-full mt-6 text-center inline-flex items-center justify-center gap-2">
								Get started
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
							<div class="mt-4 grid grid-cols-2 gap-3">
								<a href="tel:+251911234567" class="btn bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-white w-full text-center inline-flex items-center justify-center gap-2 py-2 text-sm rounded-lg transition-colors">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
									Call us
								</a>
								<a href="mailto:info@mekanplc.com" class="btn bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-800 dark:text-white w-full text-center inline-flex items-center justify-center gap-2 py-2 text-sm rounded-lg transition-colors">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
									Email us
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* Our Work Gallery Section */}
	<section class="section bg-[hsl(var(--background))] border-t border-white/10">
		<div class="container">
			<div class="text-center max-w-2xl mx-auto mb-8">
				<h2 class="text-2xl font-semibold tracking-tight text-[hsl(var(--foreground))]">Our Work</h2>
				<p class="mt-2 text-[hsl(var(--muted-foreground))]">
					See real results from our {service.title.toLowerCase()} projects across Ethiopia.
				</p>
				<button 
					onclick="document.getElementById('work-gallery-' + '{id}').classList.toggle('hidden');this.querySelector('svg').classList.toggle('rotate-180')"
					class="mt-4 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#0F2C59] dark:bg-[#7EA2CE] text-white font-medium hover:bg-[#0F2C59]/90 dark:hover:bg-[#7EA2CE]/90 transition-all"
				>
					<span>View our projects</span>
					<svg class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
			</div>
			
			{/* Collapsible Gallery */}
			<div id={`work-gallery-${id}`} class="hidden">
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{/* Placeholder - Add your images to /public/work/{id}/ folder */}
					<div class="aspect-[4/3] rounded-xl bg-slate-200 dark:bg-[#1F2937] flex items-center justify-center overflow-hidden group cursor-pointer hover:ring-2 hover:ring-[#0F2C59] dark:hover:ring-[#7EA2CE] transition-all">
						<div class="text-center p-4">
							<svg class="w-12 h-12 mx-auto text-slate-400 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Add image to /public/work/{id}/project-1.jpg</p>
						</div>
					</div>
					<div class="aspect-[4/3] rounded-xl bg-slate-200 dark:bg-[#1F2937] flex items-center justify-center overflow-hidden group cursor-pointer hover:ring-2 hover:ring-[#0F2C59] dark:hover:ring-[#7EA2CE] transition-all">
						<div class="text-center p-4">
							<svg class="w-12 h-12 mx-auto text-slate-400 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Add image to /public/work/{id}/project-2.jpg</p>
						</div>
					</div>
					<div class="aspect-[4/3] rounded-xl bg-slate-200 dark:bg-[#1F2937] flex items-center justify-center overflow-hidden group cursor-pointer hover:ring-2 hover:ring-[#0F2C59] dark:hover:ring-[#7EA2CE] transition-all">
						<div class="text-center p-4">
							<svg class="w-12 h-12 mx-auto text-slate-400 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
							</svg>
							<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Add image to /public/work/{id}/project-3.jpg</p>
						</div>
					</div>
				</div>
				<p class="mt-6 text-center text-sm text-[hsl(var(--muted-foreground))]">
					To add images, place them in <code class="bg-slate-200 dark:bg-slate-700 px-2 py-1 rounded text-xs">/public/work/{id}/</code> folder and update the code to use <code class="bg-slate-200 dark:bg-slate-700 px-2 py-1 rounded text-xs">&lt;img&gt;</code> tags.
				</p>
			</div>
		</div>
	</section>
</Layout>
