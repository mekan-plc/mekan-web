---
import Layout from '../../layouts/Layout.astro';

const services = [
	{
		id: 'quality-assurance',
		title: 'Quality Assurance & Regulatory Compliance',
		summary: 'Food safety systems, private label standards, EU export readiness, and benchmarking.'
	},
	{
		id: 'agribusiness-development',
		title: 'Agribusiness Development & Strategic Growth',
		summary: 'Scaling strategies, SME business plans, performance monitoring, and value chain development.'
	},
	{
		id: 'agricultural-productivity',
		title: 'Agricultural Productivity & Sustainability',
		summary: 'GAP implementation, postharvest safety, IPM, and integrated farm management.'
	},
	{
		id: 'food-systems',
		title: 'Food Systems & Climate Resilience',
		summary: 'Diagnostics, policy strategy, climate risk management, and nutrition programming.'
	},
	{
		id: 'capacity-building',
		title: 'Capacity Building & Training',
		summary: 'Practical skills transfer, field-level training, and organizational development.'
	},
	{
		id: 'certification-support',
		title: 'Certification & Audit Support',
		summary: 'Third-party representation, gap analysis, and preparation for GlobalG.A.P., BRCGS, IFS.'
	}
];
---

<Layout title="Services | Mekan">
	<section class="bg-[hsl(var(--brand))] text-[hsl(var(--brand-foreground))]">
		<div class="container py-24">
			<h1 class="text-3xl md:text-4xl font-semibold tracking-tight">Our Services</h1>
			<p class="mt-4 text-lg text-[hsl(var(--brand-foreground))]/80 max-w-2xl">
				Comprehensive consulting solutions for agribusinesses at every stage of growth. From certification support to strategic growth planning.
			</p>
		</div>
	</section>

	<section class="section bg-[hsl(var(--background))]">
		<div class="container">
			<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				{services.map((service) => (
					<div class="card p-8 transition-all hover:shadow-md hover:-translate-y-1 flex flex-col">
						<h3 class="text-xl font-semibold">{service.title}</h3>
						<p class="mt-3 text-sm leading-relaxed text-[hsl(var(--muted-foreground))] flex-grow">
							{service.summary}
						</p>
						<a 
							href={`/services/${service.id}`} 
							class="mt-6 btn btn-secondary w-full text-center"
						>
							Learn more
						</a>
					</div>
				))}
			</div>

			<div class="mt-16 card-muted p-8 text-center">
				<h2 class="text-2xl font-semibold tracking-tight">Need a custom solution?</h2>
				<p class="mt-3 text-[hsl(var(--muted-foreground))] max-w-xl mx-auto">
					Every agribusiness is unique. Contact us to discuss a tailored consulting engagement that fits your specific needs.
				</p>
				<a href="/contact" class="btn btn-primary mt-6 inline-block">
					Get in touch
				</a>
			</div>
		</div>
	</section>
</Layout>
