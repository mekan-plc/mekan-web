---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Server Error" description="Something went wrong on our end. Please try again, or contact Mekan PLC for support." overlayNav>
	<div class="min-h-screen bg-[hsl(var(--background))] flex flex-col">
		{/* Hero Section with 500 Message */}
		<section class="relative flex-1 flex items-center justify-center overflow-hidden">
			{/* Background Pattern */}
			<div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/logo.png');"></div>
			<div class="absolute inset-0 bg-gradient-to-br from-[#0F2C59] via-[#1a3a6e] to-[#0F2C59]"></div>
			
			{/* Decorative Elements */}
			<div class="absolute top-20 left-10 w-72 h-72 bg-[#7EA2CE]/10 rounded-full blur-3xl"></div>
			<div class="absolute bottom-20 right-10 w-96 h-96 bg-[#7EA2CE]/10 rounded-full blur-3xl"></div>
			
			{/* Content */}
			<div class="relative z-10 container max-w-4xl mx-auto px-4 text-center pt-20 pb-8">
				{/* 500 Number */}
				<div class="-mb-8">
					<span class="text-[10rem] md:text-[12rem] leading-none font-bold text-white/20 select-none">500</span>
				</div>
				
				{/* Icon */}
				<div class="relative z-20 w-16 h-16 mx-auto mb-3 rounded-xl bg-white/10 backdrop-blur-sm flex items-center justify-center border border-white/20">
					<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
					</svg>
				</div>
				
				{/* Heading */}
				<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-2">
					Something Went Wrong
				</h1>
				
				{/* Description */}
				<p class="text-base md:text-lg text-white/80 mb-4 max-w-xl mx-auto leading-relaxed">
					We're experiencing a temporary issue. Try refreshing or contact us.
				</p>
				
				{/* Action Buttons */}
				<div class="flex flex-col sm:flex-row gap-3 justify-center pt-2">
					<button 
						onclick="window.location.reload()"
						class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-[#0F2C59] rounded-xl font-semibold transition-all hover:bg-white/90 hover:shadow-lg hover:shadow-white/20 hover:-translate-y-0.5 cursor-pointer"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
						</svg>
						Refresh Page
					</button>
					<a 
						href="/#contact" 
						class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 text-white rounded-xl font-semibold border border-white/30 transition-all hover:bg-white/20 hover:border-white/50"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
						</svg>
						Call Us Now
					</a>
				</div>
			</div>
		</section>
	</div>
</Layout>
