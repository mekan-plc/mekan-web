---
import Layout from '../layouts/Layout.astro';

const title = "Privacy Policy";
const description = "Learn how Mekan PLC collects, uses, and protects your personal information.";

const sections = [
  { id: 'introduction', num: '1', title: 'Introduction', icon: 'document' },
  { id: 'information', num: '2', title: 'Information We Collect', icon: 'eye' },
  { id: 'usage', num: '3', title: 'How We Use Your Information', icon: 'usage' },
  { id: 'security', num: '4', title: 'Data Security', icon: 'shield' },
  { id: 'rights', num: '5', title: 'Your Rights', icon: 'user' },
  { id: 'contact', num: '6', title: 'Contact Us', icon: 'mail' },
];

const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={title} description={description} overlayNav={true}>
  <!-- Hero Section -->
  <section class="relative bg-[#0F2C59] dark:bg-[#0F2C59] pt-40 pb-16 -mt-[72px]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm mb-8">
        <a href="/" class="flex items-center gap-1 px-3 py-1.5 rounded-full border border-white/20 text-white/80 hover:text-white hover:border-white/40 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Home
        </a>
        <span class="text-white/40">›</span>
        <span class="px-3 py-1.5 rounded-full border border-[#7EA2CE]/50 text-[#7EA2CE] bg-[#7EA2CE]/10">
          Privacy Policy
        </span>
      </nav>

      <!-- Legal Label -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-[#7EA2CE]/50"></div>
        <span class="text-[#7EA2CE] text-sm tracking-widest uppercase font-medium">LEGAL</span>
        <div class="h-px w-12 bg-[#7EA2CE]/50"></div>
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-center text-[#7EA2CE] mb-4">
        Privacy Policy
      </h1>

      <!-- Subtitle -->
      <p class="text-center text-white/80 text-lg mb-6">
        Your Data. Your Trust. Our Responsibility.
      </p>

      <!-- Last Updated -->
      <div class="flex items-center justify-center gap-2 text-white/60 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>Last updated: {lastUpdated}</span>
      </div>
    </div>
  </section>

  <!-- Quick Navigation -->
  <section class="bg-[hsl(var(--background))] relative z-10 mt-6">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[hsl(var(--card))] rounded-xl shadow-lg p-6 sm:p-8 border border-[#0F2C59]/20 dark:border-[#7EA2CE]/20">
        <h2 class="text-[#0F2C59] dark:text-[#7EA2CE] text-lg font-semibold mb-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Quick Navigation
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {sections.map((section) => (
            <a 
              href={`#${section.id}`} 
              class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#0F2C59]/10 dark:hover:bg-[#7EA2CE]/10 transition-colors group"
            >
              <div class="w-8 h-8 rounded-lg bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] group-hover:bg-[#0F2C59] group-hover:text-white dark:group-hover:bg-[#7EA2CE] dark:group-hover:text-white dark:hover:text-[#0F2C59] transition-colors">
                <span class="text-sm font-bold">{section.num}</span>
              </div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] font-medium">{section.title}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <section class="bg-[hsl(var(--background))] py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
      
      <!-- Section 1: Introduction -->
      <div id="introduction" class="bg-[hsl(var(--card))] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 1</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Introduction</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed">
            Mekan Consultancy respects your privacy and is committed to protecting your personal data. This privacy policy explains how we collect, use, and safeguard your information when you use our website and services. By using our website, you agree to the practices described in this policy.
          </p>
        </div>
      </div>

      <!-- Section 2: Information We Collect -->
      <div id="information" class="bg-[hsl(var(--card))] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 2</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Information We Collect</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            We collect information you provide directly to us, including:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Personal Information:</strong> Name, email address, phone number that you provide through our contact form.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Service Preferences:</strong> Information about the agribusiness services you're interested in.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Communication Data:</strong> Messages and inquiries you send to us.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Technical Information:</strong> IP address, browser type for security and analytics.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 3: How We Use Your Information -->
      <div id="usage" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 3</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">How We Use Your Information</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            Mekan Consultancy uses your personal information for:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Responding to Inquiries:</strong> Contacting you regarding your agribusiness consulting needs.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Service Delivery:</strong> Providing the investment advisory and consulting services you requested.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Communication:</strong> Sending updates about our services and responses to your questions.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Legal Compliance:</strong> Complying with applicable laws and regulations.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 4: Data Security -->
      <div id="security" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 4</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Data Security</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            We take the security of your personal information seriously:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Your data is stored on secure servers with industry-standard encryption.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Access is restricted to authorized Mekan Consultancy personnel only.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>We implement technical and organizational measures to protect against unauthorized access.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span>Your information is retained for up to 2 years after our last interaction.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 5: Your Rights -->
      <div id="rights" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 5</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Your Rights</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed mb-4">
            Depending on your location, you have the following rights:
          </p>
          <ul class="space-y-3 text-slate-700 dark:text-white/70">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Access:</strong> Request a copy of the personal information we hold about you.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Correction:</strong> Request that we correct inaccurate or incomplete information.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Deletion:</strong> Request that we delete your personal information.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-[#0F2C59] dark:bg-[#7EA2CE] mt-2 shrink-0"></span>
              <span><strong>Objection:</strong> Object to certain types of processing.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Section 6: Contact Us -->
      <div id="contact" class="bg-slate-100 dark:bg-[#1F2937] rounded-xl shadow-md border-l-4 border-[#0F2C59] dark:border-[#7EA2CE] overflow-hidden">
        <div class="p-6 sm:p-8">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-[#0F2C59]/10 dark:bg-[#7EA2CE]/15 flex items-center justify-center text-[#0F2C59] dark:text-[#7EA2CE] shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <span class="text-[#0F2C59] dark:text-[#7EA2CE] text-xs font-semibold tracking-wider uppercase">Section 6</span>
              <h2 class="text-xl sm:text-2xl font-bold text-[#0F2C59] dark:text-white">Contact Us</h2>
            </div>
          </div>
          <p class="text-slate-700 dark:text-white/70 leading-relaxed">
            If you have any questions about this privacy policy or our data practices, please contact us at <a href="mailto:biniam@mekanplc.com" class="text-[#0F2C59] dark:text-[#7EA2CE] hover:underline font-medium">biniam@mekanplc.com</a>.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-[hsl(var(--background))] py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[#0F2C59] dark:bg-[#0F2C59] rounded-2xl p-8 sm:p-12 text-center">
        <div class="w-16 h-16 rounded-xl bg-white/20 flex items-center justify-center text-white mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Questions About Your Privacy?</h2>
        <p class="text-white/80 mb-8 max-w-lg mx-auto">
          We're committed to protecting your data. If you have any questions about our privacy practices, our team is here to help.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="mailto:biniam@mekanplc.com" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[#0F2C59] rounded-lg font-medium hover:bg-white/90 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Email Privacy Team
          </a>
          <a href="/#contact" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/30 text-white rounded-lg font-medium hover:bg-white/10 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
