---
interface Partner {
	name: string;
	logo: string;
	url: string;
}

const partners: Partner[] = [
	{ name: "Gena Investment Group", logo: "/partners/Gena investment group.jpg", url: "https://genaigroup.com/" },
	{ name: "Colead Maheber Ethiopia", logo: "/partners/Colead mahaber prrogram.jpg", url: "https://colead.link/programmes-page/maheber-ethiopia/" },
	{ name: "Colead Fit for Market Plus", logo: "/partners/Colead fit for market.jpg", url: "https://colead.link/programmes-page/fit-for-market-plus/" },
	{ name: "The Day Agro Industry", logo: "/partners/Theday Agro Industry.jpg", url: "http://thedayjam.com/" },
	{ name: "Mahader Foods", logo: "/partners/Mahader foods and catering.jpg", url: "https://mahederfoods.com/service/" },
	{ name: "Vegpro Agriculture PLC", logo: "/partners/Ethio Vegpro farm.jpg", url: "https://freshdi.com/supplier/VEGPRO-AGRICULTURE-PLC" },
	{ name: "Almeta Impex PLC", logo: "/partners/Almeta koka farm.jpg", url: "https://web.facebook.com/p/Almeta-Impex-PLC-100093981290055/" },
	{ name: "Greenpath Food Ethiopia", logo: "/partners/Greenpath farm Ethiopia.jpg", url: "https://ethiopiandiasporafellowship.org/portfolio/greenpath-food-3/" }
];
---

<section class="relative overflow-hidden">
	<div class="container mb-8">
		<p class="text-center text-sm font-medium tracking-wide text-[hsl(var(--brand-foreground))]/70 uppercase">Trusted by Industry Leaders</p>
	</div>

	<div class="relative" id="partnersMarquee">
		<div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[hsl(var(--brand))] to-transparent z-10 pointer-events-none"></div>
		<div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[hsl(var(--brand))] to-transparent z-10 pointer-events-none"></div>

		<div class="flex" id="marqueeTrack" style="will-change: transform;">
			{partners.map((partner) => (
				<a href={partner.url} target="_blank" rel="noopener noreferrer" class="partner-logo flex-shrink-0 mx-8 group relative" aria-label={`Visit ${partner.name}`}>
					<img src={partner.logo} alt={partner.name} class="w-32 h-20 md:w-40 md:h-24 object-contain transition-all duration-500 group-hover:scale-105" loading="lazy" />
					<div class="absolute -bottom-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap">
						<span class="text-xs font-medium text-[hsl(var(--brand-foreground))]/80 bg-black/20 px-3 py-1 rounded-full backdrop-blur-sm">{partner.name}</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<script>
	const partners = [
		{ name: "Gena Investment Group", logo: "/partners/Gena investment group.jpg", url: "https://genaigroup.com/" },
		{ name: "Colead Maheber Ethiopia", logo: "/partners/Colead mahaber prrogram.jpg", url: "https://colead.link/programmes-page/maheber-ethiopia/" },
		{ name: "Colead Fit for Market Plus", logo: "/partners/Colead fit for market.jpg", url: "https://colead.link/programmes-page/fit-for-market-plus/" },
		{ name: "The Day Agro Industry", logo: "/partners/Theday Agro Industry.jpg", url: "http://thedayjam.com/" },
		{ name: "Mahader Foods", logo: "/partners/Mahader foods and catering.jpg", url: "https://mahederfoods.com/service/" },
		{ name: "Vegpro Agriculture PLC", logo: "/partners/Ethio Vegpro farm.jpg", url: "https://freshdi.com/supplier/VEGPRO-AGRICULTURE-PLC" },
		{ name: "Almeta Impex PLC", logo: "/partners/Almeta koka farm.jpg", url: "https://web.facebook.com/p/Almeta-Impex-PLC-100093981290055/" },
		{ name: "Greenpath Food Ethiopia", logo: "/partners/Greenpath farm Ethiopia.jpg", url: "https://ethiopiandiasporafellowship.org/portfolio/greenpath-food-3/" }
	];

	document.addEventListener('DOMContentLoaded', () => {
		const track = document.getElementById('marqueeTrack');
		const marquee = document.getElementById('partnersMarquee');
		if (!track || !marquee) return;

		// Fill with 8 initial copies
		const initialHTML = track.innerHTML;
		track.innerHTML = initialHTML.repeat(8);

		const firstItem = track.querySelector('.partner-logo');
		if (!firstItem) return;

		const itemStyle = window.getComputedStyle(firstItem);
		const itemWidth = firstItem.getBoundingClientRect().width + parseFloat(itemStyle.marginLeft) + parseFloat(itemStyle.marginRight);

		let position = 0;
		let isPaused = false;
		let speed = 0.5;
		let nextIndex = 0;

		function createElement(partner) {
			const a = document.createElement('a');
			a.href = partner.url;
			a.target = '_blank';
			a.rel = 'noopener noreferrer';
			a.className = 'partner-logo flex-shrink-0 mx-8 group relative';
			a.setAttribute('aria-label', `Visit ${partner.name}`);
			a.innerHTML = `<img src="${partner.logo}" alt="${partner.name}" class="w-32 h-20 md:w-40 md:h-24 object-contain transition-all duration-500 group-hover:scale-105" loading="lazy" /><div class="absolute -bottom-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap"><span class="text-xs font-medium text-[hsl(var(--brand-foreground))]/80 bg-black/20 px-3 py-1 rounded-full backdrop-blur-sm">${partner.name}</span></div>`;
			return a;
		}

		function animate() {
			if (!isPaused) {
				position -= speed;
				const items = track.querySelectorAll('.partner-logo');

				if (Math.abs(position) >= itemWidth && items.length > 0) {
					items[0].remove();
					position += itemWidth;
					track.appendChild(createElement(partners[nextIndex]));
					nextIndex = (nextIndex + 1) % 8;
				}

				track.style.transform = `translateX(${position}px)`;
			}
			requestAnimationFrame(animate);
		}

		requestAnimationFrame(animate);
		marquee.addEventListener('mouseenter', () => isPaused = true);
		marquee.addEventListener('mouseleave', () => isPaused = false);
	});
</script>

